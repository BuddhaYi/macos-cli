_KB_CACHE = None


def _kb_index():
    global _KB_CACHE
    if _KB_CACHE is not None: return _KB_CACHE
    if not MACOS_AUTOMATOR_KB.is_dir():
        _KB_CACHE = {}; return _KB_CACHE
    idx = {}
    for md in MACOS_AUTOMATOR_KB.rglob("*.md"):
        try: content = md.read_text(encoding="utf-8")
        except OSError: continue
        m = re.search(r"^id:\s*([\w-]+)\s*$", content, re.MULTILINE)
        if m: idx[m.group(1)] = md
    _KB_CACHE = idx
    return idx


def _kb_extract_script(md_path):
    text = md_path.read_text(encoding="utf-8")
    blocks = re.findall(r"```(?:applescript|javascript)?\s*\n(.*?)\n```", text, re.DOTALL)
    if not blocks: return None, None
    fm = re.search(r"^language:\s*(\w+)\s*$", text, re.MULTILINE)
    return blocks[0], (fm.group(1) if fm else "applescript")


def cmd_mac_kb(args):
    if not args:
        print("usage: tx mac kb <script-id> [arg1 ...]", file=sys.stderr); return 2
    script_id, script_args = args[0], args[1:]
    idx = _kb_index()
    if script_id not in idx:
        print(f"tx mac kb: id '{script_id}' not found", file=sys.stderr); return 1
    script, lang = _kb_extract_script(idx[script_id])
    if script is None:
        print(f"tx mac kb: no code block in {idx[script_id]}", file=sys.stderr); return 1
    for i, val in enumerate(script_args, 1):
        script = script.replace(f"--MCP_ARG_{i}", val)
    cmd = ["osascript"] + (["-l", "JavaScript"] if lang.lower() in ("javascript", "jxa") else []) + ["-e", script]
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
    sys.stdout.write(r.stdout); sys.stderr.write(r.stderr)
    return r.returncode


def cmd_mac_kb_list(args):
    idx = _kb_index()
    for kb_id in sorted(idx):
        rel = idx[kb_id].relative_to(MACOS_AUTOMATOR_KB)
        print(f"  {kb_id:48s}  {rel}")
    print(f"\n({len(idx)} scripts)")
    return 0


def cmd_mac_script(args):
    if not args:
        print("usage: tx mac script '<applescript code>'", file=sys.stderr); return 2
    r = osascript(args[0], timeout=60)
    sys.stdout.write(r.stdout); sys.stderr.write(r.stderr)
    return r.returncode


def cmd_mac_dark_mode(args):
    if not args or args[0] not in ("on", "off", "toggle"):
        print("usage: tx mac dark-mode <on|off|toggle>", file=sys.stderr); return 2
    state = args[0]
    if state == "toggle":
        script = 'tell app "System Events" to tell appearance preferences to set dark mode to not dark mode'
    else:
        script = f'tell app "System Events" to tell appearance preferences to set dark mode to {state == "on"}'
    r = osascript(script)
    if r.returncode != 0:
        print(r.stderr.strip(), file=sys.stderr)
    else:
        print(f"✓ dark mode {state}")
    return r.returncode


def cmd_mac_volume(args):
    if not args:
        r = osascript('output volume of (get volume settings)')
        print(r.stdout.strip()); return 0
    try: vol = int(args[0])
    except ValueError:
        print("usage: tx mac volume <0-100>", file=sys.stderr); return 2
    osascript(f'set volume output volume {vol}')
    print(f"✓ volume = {vol}")
    return 0


def route_mac(args):
    if not args:
        print("usage: tx mac <kb|kb-list|script|dark-mode|volume>", file=sys.stderr); return 2
    sub, rest = args[0], args[1:]
    if sub == "kb":         return cmd_mac_kb(rest)
    if sub == "kb-list":    return cmd_mac_kb_list(rest)
    if sub == "script":     return cmd_mac_script(rest)
    if sub == "dark-mode":  return cmd_mac_dark_mode(rest)
    if sub == "volume":     return cmd_mac_volume(rest)
    print(f"tx mac: unknown subcommand '{sub}'", file=sys.stderr); return 2


