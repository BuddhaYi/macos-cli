#!/usr/bin/env python3
"""tx — unified router across 3 X/Twitter backends + 132 site adapters.

Backends:
  bird          npm @steipete/bird          plain-HTTPS GraphQL (fallback for unique cmds)
  twitter-cli   uv tool twitter-cli         curl_cffi + TLS impersonation + write jitter ⭐
  opencli       npm @jackwener/opencli      Chromium browser bridge (132 site adapters)

Routing rules (after stripping global flags):
  1. internal cmd (auth/archive/cookies-save/doctor/help)              → handled here
  2. tx bird|twitter-cli <args...>                                     → exec respective tool
  3. tx <site> <args...>                                               → exec opencli <site>
  4. tx --via <bird|twitter-cli|opencli> <cmd>                         → forced backend
  5. cmd in twitter-cli                                                → twitter-cli (TLS, best for X)
  6. cmd in bird                                                       → bird (mentions/news/about)
  7. cmd in opencli                                                    → opencli (block/notif/etc)
  8. unknown                                                           → suggest similar, exit 2

Global flags (must come BEFORE the subcommand):
  --refresh                            rebuild discovery cache
  --version                            print version
  --via <bird|twitter-cli|opencli>     force backend
  --help / -h                          show this help
  --                                   end of tx flags (rest is passthrough)

Cache: ~/.tx/cache.json (rebuilt every 7d or via --refresh).
Cookies: ~/.tx/cookies.env exports both bird-style (AUTH_TOKEN) and
         twitter-cli-style (TWITTER_AUTH_TOKEN) — extract once via tx cookies-save.
"""
import difflib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path

VERSION = "0.3.0"
CACHE_DIR = Path.home() / ".tx"
CACHE_FILE = CACHE_DIR / "cache.json"
CONFIG_FILE = CACHE_DIR / "config.json"
CACHE_TTL = 7 * 24 * 3600  # 7 days

# Default download preferences — override via ~/.tx/config.json:
#   {"download": {"video_quality": "max", "image_quality": "orig"}}
# video_quality: max | medium | low | <kbps int>
# image_quality: orig | large | medium | small
DEFAULT_CONFIG = {
    "download": {
        "video_quality": "max",
        "image_quality": "orig",
    }
}


def _load_config():
    if not CONFIG_FILE.exists():
        return DEFAULT_CONFIG
    try:
        user = json.loads(CONFIG_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return DEFAULT_CONFIG
    # shallow-merge with defaults
    merged = {k: dict(v) if isinstance(v, dict) else v for k, v in DEFAULT_CONFIG.items()}
    for k, v in user.items():
        if isinstance(v, dict) and isinstance(merged.get(k), dict):
            merged[k].update(v)
        else:
            merged[k] = v
    return merged

INTERNAL_CMDS = {"auth", "archive", "cookies-save", "doctor", "download", "help"}
COOKIES_FILE = CACHE_DIR / "cookies.env"
NPM_GLOBAL_LIB = Path.home() / ".npm-global" / "lib" / "node_modules"

# ---------- Discovery ----------

def _run(args):
    try:
        return subprocess.run(args, capture_output=True, text=True, timeout=15)
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return None


def parse_bird_cmds():
    if not shutil.which("bird"):
        return set()
    res = _run(["bird", "--help"])
    if not res or res.returncode != 0:
        return set()
    cmds = set()
    in_section = False
    for line in res.stdout.splitlines():
        stripped = line.strip()
        if stripped.startswith("Commands:"):
            in_section = True
            continue
        if in_section and (stripped.startswith("Examples") or stripped == ""):
            if stripped.startswith("Examples"):
                break
            continue
        if in_section:
            m = re.match(r"\s+([a-z][\w|-]*)", line)
            if m:
                for n in m.group(1).split("|"):
                    cmds.add(n)
    return cmds


def parse_twitter_cli_cmds():
    """Parse `twitter --help` for top-level subcommands.

    twitter-cli (jackwener/twitter-cli) is a Python X CLI with TLS-fingerprint
    impersonation via curl_cffi — preferred over bird for both reads and writes
    when available. Install: `uv tool install twitter-cli` or `pipx install twitter-cli`.
    """
    if not shutil.which("twitter"):
        return set()
    res = _run(["twitter", "--help"])
    if not res or res.returncode != 0:
        return set()
    cmds = set()
    in_section = False
    for line in res.stdout.splitlines():
        if line.startswith("Commands:"):
            in_section = True
            continue
        if in_section:
            m = re.match(r"^\s+([a-z][\w-]*)\s+\S", line)
            if m:
                cmds.add(m.group(1))
            elif line.strip() == "":
                continue
    return cmds


def parse_opencli_twitter():
    if not shutil.which("opencli"):
        return {}
    res = _run(["opencli", "twitter", "--help"])
    if not res or res.returncode != 0:
        return {}
    cmds = {}
    for line in res.stdout.splitlines():
        m = re.match(r"\s+([a-z][\w-]*)\s.*\[(read|write)\]", line)
        if m:
            cmds[m.group(1)] = m.group(2)
    return cmds


def parse_opencli_adapters():
    """Return set of adapter names from `opencli list`.

    Format: each adapter is a 2-space-indented bare identifier on its own line,
    followed by 4-space-indented sub-command lines. Example:
        2-space indent ▸ 1688
        4-space indent ▸     assets [cookie] — ...
    """
    if not shutil.which("opencli"):
        return set()
    res = _run(["opencli", "list"])
    if not res or res.returncode != 0:
        return set()
    names = set()
    for line in res.stdout.splitlines():
        # exactly 2 leading spaces, then a bare identifier, nothing else
        m = re.match(r"^  ([a-z][\w-]*)\s*$", line)
        if m:
            names.add(m.group(1))
    return names


def build_cache():
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    data = {
        "version": 2,
        "built_at": time.time(),
        "bird": sorted(parse_bird_cmds()),
        "twitter_cli": sorted(parse_twitter_cli_cmds()),
        "opencli_twitter": parse_opencli_twitter(),
        "opencli_sites": sorted(parse_opencli_adapters()),
    }
    # atomic write
    fd, tmp = tempfile.mkstemp(dir=str(CACHE_DIR), prefix=".cache.", suffix=".json")
    try:
        with os.fdopen(fd, "w") as f:
            json.dump(data, f, indent=2)
        os.replace(tmp, CACHE_FILE)
    except Exception:
        try: os.unlink(tmp)
        except OSError: pass
        raise
    return data


def load_cache(force_refresh=False):
    if force_refresh:
        return build_cache()
    if not CACHE_FILE.exists():
        return build_cache()
    if time.time() - CACHE_FILE.stat().st_mtime > CACHE_TTL:
        return build_cache()
    try:
        data = json.loads(CACHE_FILE.read_text())
        # backfill v1 caches missing twitter_cli key (v0.2 → v0.3 migration)
        if "twitter_cli" not in data:
            return build_cache()
        return data
    except (json.JSONDecodeError, OSError):
        return build_cache()


