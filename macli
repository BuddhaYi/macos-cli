def _pyi_tool():
    """Return ('pipx', None) | ('uv', None) | (None, msg) — match install.sh's order."""
    if shutil.which("pipx"):
        return "pipx", None
    if shutil.which("uv"):
        return "uv", None
    return None, "neither pipx nor uv is installed (brew install pipx)"


def _doctor_repairs():
    """Diagnose missing vendor pieces and attempt minimal repairs.

    Returns list of (name, ok, detail) tuples. Detail is short stderr/msg.
    Mirrors install.sh but only fires for what's actually broken.
    """
    repairs = []

    def npm_build_and_link(name, subdir, also_install=False):
        d = VENDOR / subdir
        if not d.is_dir():
            return (name, False, f"vendor dir missing: {d}")
        try:
            if also_install:
                subprocess.run(["npm", "install", "--silent"],
                               cwd=str(d), capture_output=True, text=True, timeout=240)
                subprocess.run(["npm", "run", "build"],
                               cwd=str(d), capture_output=True, text=True, timeout=240)
            r = subprocess.run(["npm", "link", "--silent"],
                               cwd=str(d), capture_output=True, text=True, timeout=120)
            ok = r.returncode == 0 and shutil.which(name) is not None
            return (name, ok, "" if ok else (r.stderr or r.stdout).strip()[:200])
        except (subprocess.TimeoutExpired, FileNotFoundError) as e:
            return (name, False, str(e)[:200])

    # 1. bird — already built; just needs `npm link`
    if not shutil.which("bird"):
        repairs.append(npm_build_and_link("bird", "bird"))

    # 2. opencli — install + build + link
    if not shutil.which("opencli"):
        repairs.append(npm_build_and_link("opencli", "opencli", also_install=True))

    # 3. macos-automator-mcp — only KB used; build only if dist missing
    mc = VENDOR / "macos-automator-mcp"
    if mc.is_dir() and not (mc / "dist").is_dir():
        try:
            subprocess.run(["npm", "install", "--silent"], cwd=str(mc),
                           capture_output=True, text=True, timeout=240)
            r = subprocess.run(["npm", "run", "build"], cwd=str(mc),
                               capture_output=True, text=True, timeout=240)
            ok = (mc / "dist").is_dir()
            repairs.append(("macos-automator-mcp build", ok,
                            "" if ok else (r.stderr or r.stdout).strip()[:200]))
        except (subprocess.TimeoutExpired, FileNotFoundError) as e:
            repairs.append(("macos-automator-mcp build", False, str(e)[:200]))

    # 4. twitter-cli — pipx/uv editable install (puts `twitter` in PATH)
    if not shutil.which("twitter") and (VENDOR / "twitter-cli").is_dir():
        tool, err = _pyi_tool()
        if tool == "pipx":
            r = subprocess.run(["pipx", "install", "-e", str(VENDOR / "twitter-cli")],
                               capture_output=True, text=True, timeout=300)
            ok = r.returncode == 0 and shutil.which("twitter") is not None
            repairs.append(("twitter-cli", ok, "" if ok else r.stderr.strip()[:200]))
        elif tool == "uv":
            r = subprocess.run(["uv", "tool", "install", "-e", str(VENDOR / "twitter-cli")],
                               capture_output=True, text=True, timeout=300)
            ok = r.returncode == 0 and shutil.which("twitter") is not None
            repairs.append(("twitter-cli", ok, "" if ok else r.stderr.strip()[:200]))
        else:
            repairs.append(("twitter-cli", False, err))

    # 5. wechat-mcp — must end up at vendor/wechat-mcp/.venv (path that
    #    _wechat_python checks). pipx puts its venv elsewhere, so use a real
    #    python3 -m venv right next to the source.
    #
    #    Treat "python binary exists but `import wechat_mcp` fails" as a
    #    broken-venv case worth repairing — that's the exact footgun where a
    #    prior `pip install -e .` silently failed and left a half-built venv.
    wm = VENDOR / "wechat-mcp"
    wm_venv = wm / ".venv"
    wm_venv_py = wm_venv / "bin" / "python"

    def _venv_can_import_wechat_mcp(py_path):
        if not (py_path.is_file() and os.access(py_path, os.X_OK)):
            return False
        try:
            r = subprocess.run([str(py_path), "-c", "import wechat_mcp"],
                               capture_output=True, text=True, timeout=10)
            return r.returncode == 0
        except (subprocess.TimeoutExpired, OSError):
            return False

    if wm.is_dir() and not _venv_can_import_wechat_mcp(wm_venv_py):
        # If venv directory exists but is broken, remove it before rebuilding.
        if wm_venv.exists():
            try:
                shutil.rmtree(wm_venv)
            except OSError as e:
                repairs.append(("wechat-mcp venv (cleanup)", False, str(e)[:200]))

        # wechat-mcp's pyproject.toml requires Python >=3.12. Default `python3`
        # may resolve to an older interpreter (e.g. 3.10 in miniconda envs)
        # which silently leaves the venv with only setuptools/pip — exactly the
        # footgun this repair exists to fix.
        py_candidates = ["python3.13", "python3.12", "python3"]
        chosen_py = None
        for cand in py_candidates:
            path = shutil.which(cand)
            if not path:
                continue
            try:
                vr = subprocess.run([path, "-c",
                                     "import sys; print(sys.version_info >= (3, 12))"],
                                    capture_output=True, text=True, timeout=5)
                if vr.returncode == 0 and "True" in vr.stdout:
                    chosen_py = path
                    break
            except (subprocess.TimeoutExpired, OSError):
                continue
        if not chosen_py:
            repairs.append(("wechat-mcp venv", False,
                            "no Python ≥3.12 found on PATH (wechat-mcp requires it)"))
        else:
            try:
                r1 = subprocess.run([chosen_py, "-m", "venv", str(wm_venv)],
                                    capture_output=True, text=True, timeout=120)
                if r1.returncode != 0:
                    repairs.append(("wechat-mcp venv", False, r1.stderr.strip()[:200]))
                else:
                    pip = str(wm_venv / "bin" / "pip")
                    r2 = subprocess.run([pip, "install", "-e", str(wm)],
                                        capture_output=True, text=True, timeout=600)
                    ok = r2.returncode == 0 and _venv_can_import_wechat_mcp(wm_venv_py)
                    detail = (f"used {chosen_py}" if ok else
                              (r2.stderr or r2.stdout).strip()[:300])
                    repairs.append(("wechat-mcp venv", ok, detail))
            except (subprocess.TimeoutExpired, FileNotFoundError) as e:
                repairs.append(("wechat-mcp venv", False, str(e)[:200]))

    return repairs


