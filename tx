def cmd_x_auth(rest, cache):
    print("=== tx x auth check ===\n")
    print("[bird]")
    if shutil.which("bird"):
        r = _run(["bird", "check"])
        if r and r.returncode == 0:
            for line in r.stdout.splitlines(): print(" ", line)
        else:
            print("  ❌ bird check failed")
            if r: print(" ", (r.stderr or r.stdout).strip())
    else:
        print("  ❌ bird not installed")
    print("\n[twitter-cli]")
    if shutil.which("twitter"):
        _load_cookies_env()
        r = _run(["twitter", "status"])
        if r and r.returncode == 0:
