                "expired (renew NOW)": "🔴"}.get(label, "❓")
        print(f"  {icon} source: {source}, age: {age/86400:.1f}d, status: {label}")
    return 0


def cmd_x_help(rest, cache):
    if rest:
        sub = rest[0]
        sites = set(cache["opencli_sites"])
        bird = set(cache["bird"])
        tw = set(cache.get("twitter_cli", []))
        oc = cache["opencli_twitter"]
        if sub == "bird":         os.execvp("bird", ["bird", "--help"])
        if sub in ("twitter-cli", "twitter_cli", "twitter"): os.execvp("twitter", ["twitter", "--help"])
        if sub in sites:          os.execvp("opencli", ["opencli", sub, "--help"])
        if sub in tw:             os.execvp("twitter", ["twitter", sub, "--help"])
        if sub in bird:           os.execvp("bird", ["bird", sub, "--help"])
        if sub in oc:             os.execvp("opencli", ["opencli", "twitter", sub, "--help"])
        print(f"unknown command: {sub}", file=sys.stderr); return 2

    bird = set(cache["bird"])
    tw = set(cache.get("twitter_cli", []))
    oc = set(cache["opencli_twitter"])
    sites = sorted(cache["opencli_sites"])
    INTERNAL_OVERRIDES = {"download"}
    tw_only = sorted(tw - bird - oc)
    bird_only = sorted(bird - tw - oc - {"tweet"})
    oc_only = sorted(oc - bird - tw - INTERNAL_OVERRIDES)
    tw_wins = sorted((bird & tw) | (tw & oc) | (bird & tw & oc))

    print(f"tx x  —  X/Twitter subsystem (priority: twitter-cli > bird > opencli)")
    print()
    print(f"twitter-cli ({len(tw)} cmds, TLS impersonation):")
    if tw_wins:  print(f"  overlap (wins): {' '.join(tw_wins)}")
    if tw_only:  print(f"  only:           {' '.join(tw_only)}")
    print(f"bird-only ({len(bird_only)}, fallback): {' '.join(bird_only)}")
    print(f"opencli-only ({len(oc_only)}, browser): {' '.join(oc_only)}")
    print(f"\nINTERNAL")
    print("  tx x auth          | archive | download | cookies-save | help <cmd>")
    print(f"\nESCAPES")
    print("  tx x bird <args>           force bird")
    print("  tx x twitter-cli <args>    force twitter-cli")
    print("  tx x <site> <args>         force opencli <site>")
    print(f"\nSITE ADAPTERS ({len(sites)})")
    cols = 6
    for i in range(0, len(sites), cols):
        print(" ", "  ".join(f"{s:14s}" for s in sites[i:i + cols]))
    return 0


# ---- X dispatcher (the main route, ported from magpie) ----------------------

def route_x(argv):
    """Handle all X commands. Called with ['x', ...] stripped — argv = the rest."""
    # Peel global flags
    via, refresh = None, False
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--":
            argv = argv[i + 1:]; break
        if a in ("--help", "-h"):
            cache = load_cache()
            return cmd_x_help(argv[i + 1:], cache)
        if a == "--version":
            print(f"x subsystem (absorbed from magpie 0.3) within macos-cli {VERSION}")
            return 0
        if a == "--refresh":
            refresh = True; i += 1; continue
        if a == "--via":
            if i + 1 >= len(argv):
                print("tx x: --via requires bird|twitter-cli|opencli", file=sys.stderr); return 2
            via = argv[i + 1]
            if via not in ("bird", "twitter-cli", "twitter_cli", "opencli"):
                print(f"tx x: --via must be bird|twitter-cli|opencli, got: {via}", file=sys.stderr); return 2
            i += 2; continue
        argv = argv[i:]; break
    else:
        argv = argv[i:]

    cache = load_cache(force_refresh=refresh)
    if refresh and not argv:
        print(f"cache rebuilt: {len(cache['bird'])} bird, "
              f"{len(cache['twitter_cli'])} twitter-cli, "
              f"{len(cache['opencli_twitter'])} opencli twitter, "
              f"{len(cache['opencli_sites'])} adapters")
        return 0

    if not argv:
        return cmd_x_help([], cache)

    cmd, rest = argv[0], argv[1:]

    # X-internal commands
    if cmd == "help":         return cmd_x_help(rest, cache)
    if cmd == "auth":         return cmd_x_auth(rest, cache)
    if cmd == "archive":      return cmd_x_archive(rest, cache)
    if cmd == "cookies-save": return cmd_x_cookies_save(rest, cache)
    if cmd == "download":     return cmd_x_download(rest, cache)
    if cmd == "doctor":       return cmd_doctor(rest)  # falls through to top-level

    bird_cmds = set(cache["bird"])
    tw_cmds = set(cache.get("twitter_cli", []))
    oc_cmds = set(cache["opencli_twitter"])
    sites = set(cache["opencli_sites"])

    # --via override
    if via == "bird":
        exec_or_fail("bird", [cmd] + rest)
    if via in ("twitter-cli", "twitter_cli"):
        _load_cookies_env()
        exec_or_fail("twitter", [cmd] + rest)
    if via == "opencli":
        if cmd in sites:
            exec_or_fail("opencli", [cmd] + rest)
        exec_or_fail("opencli", ["twitter", cmd] + rest)

    # Explicit escape hatches
    if cmd == "bird":
        exec_or_fail("bird", rest)
    if cmd in ("twitter-cli", "twitter_cli"):
        _load_cookies_env()
        exec_or_fail("twitter", rest)

    # Site / app adapter
    if cmd in sites:
        exec_or_fail("opencli", [cmd] + rest)

    # Auto-route — priority: twitter-cli > bird > opencli twitter
    in_t = cmd in tw_cmds
    in_b = cmd in bird_cmds
    in_o = cmd in oc_cmds
    if in_t:
        _load_cookies_env()
        exec_or_fail("twitter", [cmd] + rest)
    if in_b:
        exec_or_fail("bird", [cmd] + rest)
    if in_o:
        exec_or_fail("opencli", ["twitter", cmd] + rest)

    # Unknown
    all_cmds = bird_cmds | oc_cmds | sites | X_INTERNAL | {"bird"}
    print(f"tx x: unknown command: {cmd}", file=sys.stderr)
    suggest_similar(cmd, all_cmds)
    print("  try: tx x help", file=sys.stderr)
    return 2


# =============================================================================
# WeChat subsystem (vendor/wechat-mcp)
# =============================================================================
#
# WeChat ops require pyobjc (ApplicationServices / AppKit). We delegate to the
# wechat-mcp venv's Python — either the vendor-local one set up by install.sh,
# or the user's existing wechat-mcp install as fallback.

def _wechat_python():
    candidates = [
        VENDOR / "wechat-mcp" / ".venv" / "bin" / "python",
        Path.home() / ".local/share/mcp-servers/wechat-mcp/.venv/bin/python",
    ]
    for p in candidates:
        if p.is_file() and os.access(p, os.X_OK):
            return p
    print("tx wx: no wechat-mcp venv found. run ./install.sh first.\n"
          f"  expected: {candidates[0]}\n"
          f"  or fallback: {candidates[1]}", file=sys.stderr)
    sys.exit(1)


def _run_wechat_helper(script):
    py = _wechat_python()
    res = subprocess.run([str(py), "-c", script], capture_output=True, text=True, timeout=60)
    if res.stderr:
        sys.stderr.write(res.stderr)
    return res


def cmd_wx_send(args):
    if len(args) < 2:
        print("usage: tx wx send <contact> <text-or-file-path>", file=sys.stderr)
        return 2
    contact, payload = args[0], args[1]
    payload_path = Path(payload)
    is_file = payload_path.is_file()

    if is_file:
        stage = f"""
import sys
from AppKit import NSPasteboard, NSURL
pb = NSPasteboard.generalPasteboard()
pb.clearContents()
pb.writeObjects_([NSURL.fileURLWithPath_({repr(str(payload_path.resolve()))})])
print("clip_ok")
"""
    else:
        stage = f"""
import subprocess
subprocess.run(['pbcopy'], input={repr(payload.encode('utf-8'))}, check=True)
print("clip_ok")
"""
    r = _run_wechat_helper(stage)
    if "clip_ok" not in r.stdout:
        print("tx wx: failed to stage clipboard", file=sys.stderr); return 1

    nav = f"""
import sys, json
from wechat_mcp.wechat_accessibility import open_chat_for_contact
res = open_chat_for_contact({repr(contact)})
print("nav_done")
print(json.dumps(res, default=str))
"""
    r = _run_wechat_helper(nav)
    if "nav_done" not in r.stdout:
        print(f"tx wx: could not navigate to '{contact}'", file=sys.stderr); return 1
    time.sleep(0.4)

    osascript('''
    tell application "WeChat" to activate
    tell application "System Events" to tell process "WeChat"
        keystroke "v" using command down
        delay 0.9
        key code 36
    end tell
    ''')
    print(f"✓ sent {'file' if is_file else 'text'} → {contact}")
    return 0


def cmd_wx_read(args):
    if not args:
        print("usage: tx wx read <contact> [--limit N]", file=sys.stderr); return 2
    contact = args[0]; limit = 10
    if "--limit" in args:
        i = args.index("--limit")
        if i + 1 < len(args):
            limit = int(args[i + 1])

    script = f"""
import json
from wechat_mcp.fetch_messages_by_chat_utils import fetch_messages_by_chat
msgs = fetch_messages_by_chat({repr(contact)}, last_n={limit})
print(json.dumps(msgs, indent=2, ensure_ascii=False, default=str))
"""
    r = _run_wechat_helper(script)
    sys.stdout.write(r.stdout)
    return r.returncode


