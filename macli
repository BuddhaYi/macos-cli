def cmd_stats(args):
    """Local-only usage statistics: bookmarks, cookies freshness, KB index.

    No telemetry — reads ~/.tx/bookmarks.db, ~/.tx/cookies.env, and the
    kb-search index file. Nothing leaves the machine.
    """
    as_json, _ = _pop_flag(args, "--json")
    import sqlite3

    # X bookmarks
    db_path = Path(os.environ.get("TX_DB", "~/.tx/bookmarks.db")).expanduser()
    bookmarks = {"total": 0, "last_synced_at": None, "top_authors": []}
    if db_path.exists():
        try:
            conn = sqlite3.connect(db_path)
            cur = conn.cursor()
            cur.execute("SELECT COUNT(*) FROM bookmarks")
            bookmarks["total"] = cur.fetchone()[0]
            cur.execute("SELECT MAX(synced_at) FROM bookmarks")
            row = cur.fetchone()
            bookmarks["last_synced_at"] = row[0] if row else None
            cur.execute(
                "SELECT author_username, COUNT(*) FROM bookmarks "
                "WHERE author_username IS NOT NULL "
                "GROUP BY author_username ORDER BY 2 DESC LIMIT 10"
            )
            bookmarks["top_authors"] = [
                {"username": a, "count": c} for (a, c) in cur.fetchall()
            ]
            conn.close()
        except sqlite3.OperationalError:
            pass

    # Cookies
    age, source, label = _cookies_status()
    cookies = {
        "source": source,
        "age_days": round(age / 86400, 2) if age is not None else None,
        "status": label,
    }

    # KB index freshness
    kb_total = len(_kb_load_search_index()) if MACOS_AUTOMATOR_KB.is_dir() else 0
    kb_idx_age_hours = None
    if KB_SEARCH_INDEX.exists():
        kb_idx_age_hours = round(
            (time.time() - KB_SEARCH_INDEX.stat().st_mtime) / 3600, 2
        )

    # Archive cron log
    archive_log = CACHE_DIR / "archive.log"
    archive_info = {"path": str(archive_log), "exists": archive_log.exists()}
    if archive_log.exists():
        st = archive_log.stat()
        archive_info["size_bytes"] = st.st_size
        archive_info["last_modified"] = time.strftime(
            "%Y-%m-%dT%H:%M:%S", time.localtime(st.st_mtime)
        )

    if as_json:
        _emit_ok({
            "bookmarks": bookmarks,
            "cookies": cookies,
            "kb": {"indexed": kb_total, "index_age_hours": kb_idx_age_hours},
            "archive_log": archive_info,
            "data_dir": str(CACHE_DIR),
        })
        return 0

    print(f"macli stats  —  local-only  ({CACHE_DIR})\n")
    print("X bookmarks:")
    print(f"  total:        {bookmarks['total']}")
    print(f"  last sync:    {bookmarks['last_synced_at'] or 'never'}")
    if bookmarks["top_authors"]:
        print("  top authors:")
        for a in bookmarks["top_authors"][:5]:
            print(f"    @{a['username']:24s}  {a['count']}")
    print()
    print("X cookies:")
    if cookies["source"]:
        print(f"  source: {cookies['source']}  ({cookies['age_days']}d, {cookies['status']})")
    else:
        print(f"  status: {cookies['status']}")
    print()
    age_part = f", index age {kb_idx_age_hours:.1f}h" if kb_idx_age_hours is not None else ""
    print(f"KB index:     {kb_total} scripts{age_part}")
    if archive_info["exists"]:
        print(f"archive cron log: {archive_log}  (last write {archive_info.get('last_modified')})")
    return 0


