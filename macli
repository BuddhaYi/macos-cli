                "ok is always a bool; schema_version is always the string '1'",
                "data may be present on either success OR failure (failure-with-context)",
                "error is present only when ok=false",
                "Streaming consumers can parse one envelope per stdout (no multi-doc concat)",
            ],
            "discover_codes": "macli help errors --json",
        }
        if as_json:
            _emit_ok(envelope_doc)
            return 0
        print(f"# macli JSON envelope (schema_version='{SCHEMA_VERSION}')\n")
        print("Success:")
        print(json.dumps(envelope_doc["success_shape"], indent=2, ensure_ascii=False))
        print("\nFailure:")
        print(json.dumps(envelope_doc["error_shape"], indent=2, ensure_ascii=False))
        print("\nRules:")
        for r in envelope_doc["rules"]:
            print(f"  - {r}")
        return 0

    # Tier 2: macli help <cmd-path> [--json] — per-command contract
    if args:
        cmd_path = " ".join(args)
        return _emit_subcommand_help(cmd_path, ["--json"] if as_json else [])

    # Tier 1: macli help [--json] — top-level overview
    if as_json:
        _emit_ok({
            "version": VERSION,
            "schema_version": SCHEMA_VERSION,
            "namespaces": NAMESPACES,
            "internal_commands": INTERNAL_COMMANDS,
            "commands": sorted(CMD_INFO.keys()),
            "discovery_commands": DISCOVERY_COMMANDS,
            "data_dir": str(CACHE_DIR),
        })
        return 0

    # Human-readable top-level help (unchanged)
    print(f"""macli {VERSION}  —  macos-cli unified router

USAGE
  macli <namespace> <action> [args...]
  macli <legacy-x-cmd> [args...]                  # auto-routed to x subsystem

NAMESPACES
  macli x  <args>          X/Twitter (twitter-cli + bird + opencli)
                        e.g. macli x search "Claude Code"
                             macli x archive
                             macli x download --tweet-url <url>
                             macli x post "hello"
  macli wx send <contact> <text|file> [--retry N] [--no-verify]
  macli wx read <contact> [--limit N]
  macli wx contacts [filter]                     # list known WeChat contacts
  macli mac script '<applescript>'
  macli mac kb <script-id> [args...]
  macli mac kb-list                              # list 492 KB scripts
  macli mac kb-search <query> [--max N]          # fuzzy keyword search
  macli mac dark-mode <on|off|toggle>
  macli mac volume [0-100]

INTERNAL
  macli doctor [--fix]     diagnose all backends; --fix auto-repairs missing pieces
  macli stats              local-only usage stats (bookmarks, cookies, KB)
  macli --version
  macli --help / -h

AGENT DISCOVERY (machine-readable)
  macli help --json                                top-level overview + namespaces
  macli <ns> --json                                list subcommands of namespace
  macli help <cmd-path> --json                     per-command synopsis + behavior + samples
  macli help errors --json                         error-code inventory
  macli help schema --json                         JSON envelope contract

EXAMPLES
  macli x search "Claude Code"
  macli x archive                                # bookmarks → ~/.tx/bookmarks.db
  macli wx send 文件传输助手 "TODO: 周三对账"     # default: verify + retry once
  macli wx send 文件传输助手 ~/Downloads/合同.pdf
  macli wx contacts 助手                          # filter contacts containing "助手"
  macli mac dark-mode on
  macli mac kb-search "save webpage as PDF"
  macli mac kb safari_save_as_pdf ~/x.pdf
""")
    return 0


def route(argv):
    if not argv or argv[0] in ("--help", "-h", "help"):
        return cmd_help(argv[1:] if argv else [])
    # Top-level `macli --json` is an alias for `macli help --json`.
    if argv == ["--json"]:
        return cmd_help(["--json"])
    if argv[0] == "--version":
        print(VERSION); return 0

    head, rest = argv[0], argv[1:]

    if head == "doctor":              return cmd_doctor(rest)
    if head == "stats":               return cmd_stats(rest)
    if head in ("x", "twitter"):      return route_x(rest)
    if head in ("wx", "wechat"):      return route_wechat(rest)
    if head in ("mac", "macos"):      return route_mac(rest)

    # Legacy magpie-style fallthrough: anything else → X subsystem
    return route_x([head] + rest)


def main():
    try:
        return route(sys.argv[1:]) or 0
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    sys.exit(main())
