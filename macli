def cmd_x_archive(rest, cache):
    import sqlite3
    from datetime import datetime
    as_json = _has_flag(rest, "--json")
    db_path = Path(os.environ.get("TX_DB", "~/.tx/bookmarks.db")).expanduser()
    db_path.parent.mkdir(parents=True, exist_ok=True)
    _load_cookies_env()

    conn = sqlite3.connect(db_path)
    cur = conn.cursor()
    cur.execute("""CREATE TABLE IF NOT EXISTS bookmarks (
        tweet_id TEXT PRIMARY KEY, text TEXT,
        author_username TEXT, author_name TEXT,
        created_at TEXT, raw_json TEXT,
        synced_at TEXT DEFAULT CURRENT_TIMESTAMP)""")
    conn.commit()

    use_twitter_cli = shutil.which("twitter") is not None
    if use_twitter_cli:
        r = _run(["twitter", "bookmarks", "--json"]); backend_label = "twitter-cli"
    else:
        r = _run(["bird", "bookmarks", "--json"]); backend_label = "bird"

    if not r or r.returncode != 0:
        err = (r.stderr if r else "no result").strip()
        is_auth = bool(r) and _is_auth_error(err)
        if is_auth:
            age, source, _ = _cookies_status()
            age_part = f"{age/86400:.0f}d old, from {source}" if age is not None else "missing"
            _notify_user(
                "macli: X cookies expired",
                f"Renew with: macli x cookies-save  ({age_part})",
            )
        if as_json:
            age, source, _ = _cookies_status() if is_auth else (None, None, None)
            _emit_err(
                "not_authenticated" if is_auth else "subprocess_failed",
                (f"cookies likely expired ({age/86400:.0f}d old, from {source})"
                 if (is_auth and age is not None)
                 else f"{backend_label} bookmarks failed: {err[:200]}"),
                data={"backend": backend_label,
                      "hint": "run: macli x cookies-save"} if is_auth else None,
            )
        else:
            print(f"{backend_label} bookmarks failed: {err}", file=sys.stderr)
            if is_auth:
                age, source, _ = _cookies_status()
                if age is None:
                    print("\n  → cookies missing. run: macli x cookies-save", file=sys.stderr)
                else:
                    print(f"\n  → cookies likely expired ({age/86400:.0f}d old, from {source}).", file=sys.stderr)
                    print("    1) Open Edge Beta → x.com → make sure logged in", file=sys.stderr)
                    print("    2) Run: macli x cookies-save", file=sys.stderr)
        conn.close()
        return 1

    try:
        parsed = json.loads(r.stdout)
        if isinstance(parsed, dict) and "data" in parsed:
            d = parsed["data"]
            tweets = d if isinstance(d, list) else d.get("tweets", [])
        else:
            tweets = parsed
    except json.JSONDecodeError as e:
        if as_json:
            _emit_err("internal_error", f"{backend_label} returned invalid JSON: {e}")
        else:
            print(f"{backend_label} returned invalid JSON: {e}", file=sys.stderr)
        conn.close()
        return 1

    cur.execute("SELECT tweet_id FROM bookmarks")
    seen = {row[0] for row in cur.fetchall()}
    new = [t for t in tweets if t.get("id") not in seen]

    for t in new:
        author = t.get("author") or {}
        username = author.get("screenName") or author.get("username")
        cur.execute("""INSERT OR REPLACE INTO bookmarks
            (tweet_id, text, author_username, author_name, created_at, raw_json, synced_at)
            VALUES (?, ?, ?, ?, ?, ?, ?)""",
            (t.get("id"), t.get("text"),
             username, author.get("name"),
             t.get("createdAt"), json.dumps(t),
             datetime.utcnow().isoformat()))
    conn.commit()
    cur.execute("SELECT COUNT(*) FROM bookmarks")
    total = cur.fetchone()[0]
    conn.close()

    if as_json:
        _emit_ok({
            "backend": backend_label,
            "new_count": len(new),
            "total_count": total,
            "db_path": str(db_path),
        })
    else:
        print(f"archived {len(new)} new bookmarks → {db_path}")
    return 0


