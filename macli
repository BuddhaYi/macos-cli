def route_mac(args):
    # Tier 1: standalone `macli mac [--json]` lists subcommands
    if not args or args == ["--json"]:
        return _emit_namespace_listing("mac", MAC_SUBCOMMANDS, args)
    sub, rest = args[0], args[1:]
    # Tier 3: --help intercept BEFORE dispatching to cmd_mac_*
    if _has_help_flag(rest) or sub in ("--help", "-h", "help"):
        target = sub if sub not in ("--help", "-h", "help") else (rest[0] if rest else None)
        if target is None or target not in MAC_SUBCOMMANDS:
            return _emit_subcommand_help("mac kb", rest)  # default to kb help
        return _emit_subcommand_help(f"mac {target}", rest)
    if sub == "kb":         return cmd_mac_kb(rest)
    if sub == "kb-list":    return cmd_mac_kb_list(rest)
    if sub == "kb-search":  return cmd_mac_kb_search(rest)
    if sub == "script":     return cmd_mac_script(rest)
    if sub == "dark-mode":  return cmd_mac_dark_mode(rest)
    if sub == "volume":     return cmd_mac_volume(rest)
    print(f"macli mac: unknown subcommand '{sub}'", file=sys.stderr); return 2


