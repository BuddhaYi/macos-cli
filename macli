def _load_config():
    if not CONFIG_FILE.exists():
        return DEFAULT_CONFIG
    try:
        user = json.loads(CONFIG_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        return DEFAULT_CONFIG
    merged = {k: dict(v) if isinstance(v, dict) else v for k, v in DEFAULT_CONFIG.items()}
    for k, v in user.items():
        if isinstance(v, dict) and isinstance(merged.get(k), dict):
            merged[k].update(v)
        else:
            merged[k] = v
    return merged


# ---- Command discovery (parse upstream --help outputs into routing table) ----

def parse_bird_cmds():
    if not shutil.which("bird"):
        return set()
    res = _run(["bird", "--help"])
    if not res or res.returncode != 0:
        return set()
    cmds = set()
    in_section = False
    for line in res.stdout.splitlines():
        stripped = line.strip()
        if stripped.startswith("Commands:"):
            in_section = True
            continue
        if in_section and (stripped.startswith("Examples") or stripped == ""):
            if stripped.startswith("Examples"):
                break
            continue
        if in_section:
            m = re.match(r"\s+([a-z][\w|-]*)", line)
            if m:
                for n in m.group(1).split("|"):
                    cmds.add(n)
    return cmds


def parse_twitter_cli_cmds():
    if not shutil.which("twitter"):
        return set()
    res = _run(["twitter", "--help"])
    if not res or res.returncode != 0:
        return set()
    cmds = set()
    in_section = False
    for line in res.stdout.splitlines():
        if line.startswith("Commands:"):
            in_section = True
            continue
        if in_section:
            m = re.match(r"^\s+([a-z][\w-]*)\s+\S", line)
            if m:
                cmds.add(m.group(1))
    return cmds


def parse_opencli_twitter():
    if not shutil.which("opencli"):
        return {}
    res = _run(["opencli", "twitter", "--help"])
    if not res or res.returncode != 0:
        return {}
    cmds = {}
    for line in res.stdout.splitlines():
        m = re.match(r"\s+([a-z][\w-]*)\s.*\[(read|write)\]", line)
        if m:
            cmds[m.group(1)] = m.group(2)
    return cmds


def parse_opencli_adapters():
    if not shutil.which("opencli"):
        return set()
    res = _run(["opencli", "list"])
    if not res or res.returncode != 0:
        return set()
    names = set()
    for line in res.stdout.splitlines():
        m = re.match(r"^  ([a-z][\w-]*)\s*$", line)
        if m:
            names.add(m.group(1))
    return names


def build_cache():
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    data = {
        "version": 2,
        "built_at": time.time(),
        "bird": sorted(parse_bird_cmds()),
        "twitter_cli": sorted(parse_twitter_cli_cmds()),
        "opencli_twitter": parse_opencli_twitter(),
        "opencli_sites": sorted(parse_opencli_adapters()),
    }
    fd, tmp = tempfile.mkstemp(dir=str(CACHE_DIR), prefix=".cache.", suffix=".json")
    try:
        with os.fdopen(fd, "w") as f:
            json.dump(data, f, indent=2)
        os.replace(tmp, CACHE_FILE)
    except Exception:
        try: os.unlink(tmp)
        except OSError: pass
        raise
    return data


def load_cache(force_refresh=False):
    if force_refresh or not CACHE_FILE.exists():
        return build_cache()
    if time.time() - CACHE_FILE.stat().st_mtime > CACHE_TTL:
        return build_cache()
    try:
        data = json.loads(CACHE_FILE.read_text())
        if "twitter_cli" not in data:
            return build_cache()
        return data
    except (json.JSONDecodeError, OSError):
        return build_cache()


# ---- Cookies management -----------------------------------------------------

def _load_cookies_env():
    if not COOKIES_FILE.exists():
        return
    try:
        for line in COOKIES_FILE.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, _, v = line.partition("=")
            k, v = k.strip(), v.strip()
            os.environ.setdefault(k, v)
            if k == "AUTH_TOKEN":
                os.environ.setdefault("TWITTER_AUTH_TOKEN", v)
            elif k == "CT0":
                os.environ.setdefault("TWITTER_CT0", v)
    except OSError:
        pass


def _cookies_status():
    if not COOKIES_FILE.exists():
        return None, None, "missing"
    try:
        age = time.time() - COOKIES_FILE.stat().st_mtime
        first_line = COOKIES_FILE.read_text().splitlines()[0]
        m = re.search(r"extracted from (\S+(?:\s+\S+)?)\s+at", first_line)
        source = m.group(1) if m else "unknown"
    except (OSError, IndexError):
        return None, None, "unreadable"
    days = age / 86400
    if days < 30:    label = "fresh"
    elif days < 60:  label = "aging"
    elif days < 90:  label = "stale (renew soon)"
    else:            label = "expired (renew NOW)"
    return age, source, label


def _is_auth_error(stderr_text):
    if not stderr_text:
        return False
    s = stderr_text.lower()
    return any(k in s for k in (
        "401", "could not authenticate", "missing required credentials",
        "no twitter cookies", "missing auth_token", "missing ct0",
    ))


def _extract_cookies_via_provider(provider_path, opts_json):
    js = (
        f"const p = require('./dist/providers/{provider_path}');"
        f"const fn = Object.values(p)[0];"
        f"fn({opts_json}, ['https://x.com','https://twitter.com'], null).then(r => {{"
        "  const cs = r.cookies || [];"
        "  const auth = cs.find(c => c.name === 'auth_token');"
        "  const ct0  = cs.find(c => c.name === 'ct0');"
        "  if (!auth || !ct0) {"
        "    console.error('no auth_token/ct0 — make sure x.com is logged in');"
        "    if (r.warnings && r.warnings.length) console.error(r.warnings.join('\\n'));"
        "    process.exit(1);"
        "  }"
        "  console.log(auth.value);"
        "  console.log(ct0.value);"
        "}).catch(e => { console.error(e.message); process.exit(1); });"
    )
    res = subprocess.run(
        ["node", "-e", js],
        cwd=str(SWEET_COOKIE_DIR),
        capture_output=True, text=True, timeout=45,
    )
    if res.returncode != 0:
        raise RuntimeError(res.stderr.strip() or "extraction failed")
    lines = res.stdout.strip().splitlines()
    if len(lines) < 2:
        raise RuntimeError(f"unexpected output: {res.stdout!r}")
    return lines[0], lines[1]


def cmd_x_cookies_save(rest, cache):
    as_json = _has_flag(rest, "--json")
    if "--check-age" in rest:
        age, source, label = _cookies_status()
        if age is None:
            if as_json:
                _emit_err("not_found", "no cookies file — run macli x cookies-save")
            else:
                print("no cookies file — run `macli x cookies-save` to create one")
            return 1
        days = age / 86400
        if as_json:
            _emit_ok({
                "source": source,
                "age_days": round(days, 2),
                "status": label,
            })
        else:
            print(f"source: {source}\nage:    {days:.1f} days\nstatus: {label}")
        return 0 if "stale" not in label and "expired" not in label else 2

    browser = "edge"
    if "--from" in rest:
        i = rest.index("--from")
        if i + 1 >= len(rest):
            print("macli x cookies-save: --from requires a value", file=sys.stderr)
            return 2
        browser = rest[i + 1]

    if not SWEET_COOKIE_DIR.exists():
        print(f"sweet-cookie not found at {SWEET_COOKIE_DIR}", file=sys.stderr)
        return 1

    common_opts = {"timeoutMs": 30000}
    profiles = {
        "edge":        ({**common_opts, "profile": str(EDGE_PROFILE_DIR)},        "edge.js",                "Edge Beta"),
        "edge-stable": ({**common_opts, "profile": str(EDGE_STABLE_PROFILE_DIR)}, "edge.js",                "Edge"),
        "chrome":      (common_opts,                                              "chrome.js",              "Chrome"),
        "safari":      (common_opts,                                              "safariBinaryCookies.js", "Safari"),
        "firefox":     (common_opts,                                              "firefoxSqlite.js",       "Firefox"),
    }
    if browser not in profiles:
        print(f"macli x cookies-save: unknown browser '{browser}'", file=sys.stderr)
        return 2
    if browser == "edge" and not EDGE_PROFILE_DIR.exists():
        print(f"Edge Beta profile not found: {EDGE_PROFILE_DIR}", file=sys.stderr)
        return 1
    opts, provider, source = profiles[browser]

    try:
        auth_token, ct0 = _extract_cookies_via_provider(provider, json.dumps(opts))
    except RuntimeError as e:
        print(f"cookie extraction failed:\n{e}", file=sys.stderr)
        return 1
    except subprocess.TimeoutExpired:
        print("cookie extraction timed out after 45s "
              "(may need Keychain approval on first run)", file=sys.stderr)
        return 1

    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=str(CACHE_DIR), prefix=".cookies.", suffix=".env")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(f"# tx cookies — extracted from {source} at {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"AUTH_TOKEN={auth_token}\nCT0={ct0}\n")
        os.chmod(tmp, 0o600)
        os.replace(tmp, COOKIES_FILE)
    except Exception:
        try: os.unlink(tmp)
        except OSError: pass
        raise
    print(f"saved → {COOKIES_FILE}  (source: {source}, mode 0600)")
    return 0


# ---- Media download helpers -------------------------------------------------

def _extract_media_urls(node, tweet_id=None, found=None):
    if found is None:
        found = []
    if isinstance(node, dict):
        if isinstance(node.get("id"), str) and isinstance(node.get("text"), str):
            tweet_id = node["id"]
        if (
            node.get("type") in ("video", "photo", "animated_gif")
            and isinstance(node.get("url"), str)
            and node["url"].startswith("http")
        ):
            entry = dict(node)
            entry["_tweet_id"] = tweet_id
            found.append(entry)
        for v in node.values():
            _extract_media_urls(v, tweet_id, found)
    elif isinstance(node, list):
        for x in node:
            _extract_media_urls(x, tweet_id, found)
    return found


def _ext_for(media):
    t = media.get("type")
    if t in ("video", "animated_gif"):
        return ".mp4"
    if t == "photo":
        url = media.get("url", "")
        for ext in (".jpg", ".jpeg", ".png", ".webp", ".gif"):
            if ext in url.lower():
                return ext
        return ".jpg"
    return ".bin"


def _curl_download(url, dest_path):
    res = subprocess.run(
        ["curl", "-fsSL", "-o", str(dest_path), url],
        capture_output=True, text=True, timeout=300,
    )
    return res.returncode == 0


def _upgrade_image_url(url, image_quality="orig"):
    if "pbs.twimg.com" not in url:
        return url
    from urllib.parse import urlparse, urlunparse, parse_qsl, urlencode
    parsed = urlparse(url)
    query = dict(parse_qsl(parsed.query))
    query["name"] = image_quality if image_quality in ("orig", "large", "medium", "small") else "orig"
    return urlunparse(parsed._replace(query=urlencode(query)))


def _get_video_variants(tweet_id):
    if not shutil.which("bird"):
        return []
    res = _run(["bird", "read", str(tweet_id), "--json-full"])
    if not res or res.returncode != 0:
        return []
    try:
        data = json.loads(res.stdout)
    except json.JSONDecodeError:
        return []
    found = []
    def walk(node):
        if isinstance(node, dict):
            if node.get("content_type") == "video/mp4" and isinstance(node.get("url"), str):
                m = re.search(r"/(\d+)x(\d+)/", node["url"])
                found.append({
                    "url": node["url"],
                    "bitrate": int(node.get("bitrate") or 0),
                    "width": int(m.group(1)) if m else 0,
                    "height": int(m.group(2)) if m else 0,
                })
            for v in node.values():
                walk(v)
        elif isinstance(node, list):
            for x in node:
                walk(x)
    walk(data)
    seen = set()
    unique = []
    for v in found:
        if v["url"] not in seen:
            seen.add(v["url"])
            unique.append(v)
    return sorted(unique, key=lambda v: (v["bitrate"], v["width"]), reverse=True)


def _select_variant(variants, preference):
    if not variants:
        return None
    if preference == "max":     return variants[0]
    if preference == "low":     return variants[-1]
    if preference == "medium":  return variants[len(variants) // 2]
    if isinstance(preference, int):
        target = preference * 1000
        return min(variants, key=lambda v: abs(v["bitrate"] - target))
    return variants[0]


_TWEET_ID_RE = re.compile(r"/status/(\d+)")


def cmd_x_download(rest, cache):
    """Download media (videos/images) from tweets via twitter-cli + curl.

    Usage:
      macli x download <username> [--limit N] [--output DIR]
      macli x download --tweet-url <url>     | --tweet-id <id>
    """
    tweet_id, username, limit = None, None, 10
    output_dir = Path("./twitter-downloads")

    i = 0
    while i < len(rest):
        a = rest[i]
        if a == "--tweet-url" and i + 1 < len(rest):
            m = _TWEET_ID_RE.search(rest[i + 1])
            if not m:
                print(f"macli x download: cannot parse tweet ID from URL: {rest[i + 1]}", file=sys.stderr)
                return 2
            tweet_id = m.group(1); i += 2
        elif a == "--tweet-id" and i + 1 < len(rest):
            tweet_id = rest[i + 1]; i += 2
        elif a in ("--limit", "-n") and i + 1 < len(rest):
            limit = int(rest[i + 1]); i += 2
        elif a in ("--output", "-o") and i + 1 < len(rest):
            output_dir = Path(rest[i + 1]).expanduser(); i += 2
        elif a.startswith("-"):
            print(f"macli x download: unknown flag: {a}", file=sys.stderr); return 2
        elif username is None and tweet_id is None:
            username = a.lstrip("@"); i += 1
        else:
            print(f"macli x download: unexpected arg: {a}", file=sys.stderr); return 2

    if not tweet_id and not username:
        print(cmd_x_download.__doc__, file=sys.stderr); return 2
    if not shutil.which("twitter"):
        print("macli x download: twitter-cli not installed", file=sys.stderr); return 1
    if not shutil.which("curl"):
        print("macli x download: curl not found", file=sys.stderr); return 1

    _load_cookies_env()
    output_dir.mkdir(parents=True, exist_ok=True)

    if tweet_id:
        cmd = ["twitter", "tweet", tweet_id, "--json"]
        label = f"tweet {tweet_id}"
    else:
        cmd = ["twitter", "user-posts", username, "--max", str(limit), "--json"]
        label = f"@{username} (recent {limit})"

    print(f"fetching media list from {label}...")
    res = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
    if res.returncode != 0:
        print(f"twitter-cli failed: {res.stderr.strip()}", file=sys.stderr); return 1
    try:
        data = json.loads(res.stdout)
    except json.JSONDecodeError as e:
        print(f"twitter-cli returned invalid JSON: {e}", file=sys.stderr); return 1

    media_list = _extract_media_urls(data)
    seen = set()
    unique = []
    for m in media_list:
        if m["url"] not in seen:
            seen.add(m["url"]); unique.append(m)

    if not unique:
        print(f"no media found in {label}"); return 1

    cfg = _load_config().get("download", {})
    video_q, image_q = cfg.get("video_quality", "max"), cfg.get("image_quality", "orig")

    print(f"found {len(unique)} media item(s), downloading to {output_dir}/")
    print(f"  quality: video={video_q}, image={image_q}")
    ok, fail = 0, 0
    variant_cache = {}
    for idx, m in enumerate(unique, 1):
        prefix = tweet_id or username
        ext = _ext_for(m)
        dest = output_dir / f"{prefix}_{idx}{ext}"
        if dest.exists():
            print(f"  [{idx}/{len(unique)}] {dest.name} already exists, skip"); continue

        download_url = m["url"]; quality_tag = ""
        m_type = m.get("type")
        if m_type == "photo":
            new_url = _upgrade_image_url(m["url"], image_q)
            if new_url != m["url"]:
                download_url = new_url
                quality_tag = f" ({image_q})"
        elif m_type in ("video", "animated_gif"):
            tid = m.get("_tweet_id")
            if tid:
                if tid not in variant_cache:
                    variant_cache[tid] = _get_video_variants(tid)
                variants = variant_cache[tid]
                chosen = _select_variant(variants, video_q)
                if chosen and chosen["url"] != m["url"]:
                    download_url = chosen["url"]
                    quality_tag = f" → {chosen['width']}x{chosen['height']} @ {chosen['bitrate']//1000}k ({video_q})"
                elif chosen:
                    quality_tag = f" ({video_q}, already best)"

        size_hint = f"{m.get('width','?')}x{m.get('height','?')}" if m_type == "video" else m_type or "?"
        print(f"  [{idx}/{len(unique)}] {size_hint}{quality_tag} → {dest.name}")
        if _curl_download(download_url, dest):
            ok += 1
        else:
            print("     ⚠️  download failed", file=sys.stderr); fail += 1

    print(f"\ndone: {ok} downloaded, {fail} failed")
    return 0 if fail == 0 else 1


