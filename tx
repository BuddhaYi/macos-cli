""")
    return 0


# ---- Main router ---------------------------------------------------------

def route(argv):
    if not argv or argv[0] in ("--help", "-h", "help"):
        return cmd_help(argv[1:] if argv else [])
    if argv[0] == "--version":
        print(VERSION)
        return 0

    head, rest = argv[0], argv[1:]

    if head == "doctor":
        return cmd_doctor(rest)
    if head in ("x", "twitter"):
        route_magpie(rest)            # execvp, no return
    if head in ("wx", "wechat"):
        return route_wechat(rest)
    if head in ("mac", "macos"):
        return route_mac(rest)

    # Fallthrough: pass to magpie (legacy / direct-magpie usage)
    route_magpie([head] + rest)


def main():
    try:
        return route(sys.argv[1:]) or 0
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    sys.exit(main())
