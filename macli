# ---- X dispatcher (the main route, ported from magpie) ----------------------

def route_x(argv):
    """Handle all X commands. Called with ['x', ...] stripped — argv = the rest."""
    # Tier 1: standalone `macli x --json` lists subcommands (synthetic — internal
    # commands only, since the full upstream-tool surface is huge; agents that
    # need the full matrix should call `macli x help --json` which uses cached
    # backend probes).
    if argv == ["--json"]:
        _emit_ok({
            "namespace": "x",
            "subcommands": X_INTERNAL_SUBCOMMANDS,
            "note": "Run `macli x help --json` for the full backend command matrix (twitter-cli / bird / opencli / 136 sites).",
            "discover_per_command": "macli help x <subcommand> --json",
        })
        return 0
    # Peel global flags
    via, refresh = None, False
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--":
            argv = argv[i + 1:]; break
        if a in ("--help", "-h"):
            cache = load_cache()
            return cmd_x_help(argv[i + 1:], cache)
        if a == "--version":
            print(f"x subsystem (absorbed from magpie 0.3) within macos-cli {VERSION}")
            return 0
        if a == "--refresh":
            refresh = True; i += 1; continue
        if a == "--via":
            if i + 1 >= len(argv):
                print("macli x: --via requires bird|twitter-cli|opencli", file=sys.stderr); return 2
            via = argv[i + 1]
            if via not in ("bird", "twitter-cli", "twitter_cli", "opencli"):
                print(f"macli x: --via must be bird|twitter-cli|opencli, got: {via}", file=sys.stderr); return 2
            i += 2; continue
        argv = argv[i:]; break
    else:
        argv = argv[i:]

    cache = load_cache(force_refresh=refresh)
    if refresh and not argv:
        print(f"cache rebuilt: {len(cache['bird'])} bird, "
              f"{len(cache['twitter_cli'])} twitter-cli, "
              f"{len(cache['opencli_twitter'])} opencli twitter, "
              f"{len(cache['opencli_sites'])} adapters")
        return 0

    if not argv:
        return cmd_x_help([], cache)

    cmd, rest = argv[0], argv[1:]

    # X-internal commands
    if cmd == "help":         return cmd_x_help(rest, cache)
    if cmd == "auth":         return cmd_x_auth(rest, cache)
    if cmd == "archive":      return cmd_x_archive(rest, cache)
    if cmd == "cookies-save": return cmd_x_cookies_save(rest, cache)
    if cmd == "download":     return cmd_x_download(rest, cache)
    if cmd == "doctor":       return cmd_doctor(rest)  # falls through to top-level

    bird_cmds = set(cache["bird"])
    tw_cmds = set(cache.get("twitter_cli", []))
    oc_cmds = set(cache["opencli_twitter"])
    sites = set(cache["opencli_sites"])

    # --via override
    if via == "bird":
        exec_or_fail("bird", [cmd] + rest)
    if via in ("twitter-cli", "twitter_cli"):
        _load_cookies_env()
        exec_or_fail("twitter", [cmd] + rest)
    if via == "opencli":
        if cmd in sites:
            exec_or_fail("opencli", [cmd] + rest)
        exec_or_fail("opencli", ["twitter", cmd] + rest)

    # Explicit escape hatches
    if cmd == "bird":
        exec_or_fail("bird", rest)
    if cmd in ("twitter-cli", "twitter_cli"):
        _load_cookies_env()
        exec_or_fail("twitter", rest)

    # Site / app adapter
    if cmd in sites:
        exec_or_fail("opencli", [cmd] + rest)

    # Auto-route — priority: twitter-cli > bird > opencli twitter
    in_t = cmd in tw_cmds
    in_b = cmd in bird_cmds
    in_o = cmd in oc_cmds
    if in_t:
        _load_cookies_env()
        exec_or_fail("twitter", [cmd] + rest)
    if in_b:
        exec_or_fail("bird", [cmd] + rest)
    if in_o:
        exec_or_fail("opencli", ["twitter", cmd] + rest)

    # Unknown
    all_cmds = bird_cmds | oc_cmds | sites | X_INTERNAL | {"bird"}
    print(f"macli x: unknown command: {cmd}", file=sys.stderr)
    suggest_similar(cmd, all_cmds)
    print("  try: macli x help", file=sys.stderr)
    return 2


# =============================================================================
# WeChat subsystem (vendor/wechat-mcp)
# =============================================================================
#
# WeChat ops require pyobjc (ApplicationServices / AppKit). We delegate to the
# wechat-mcp venv's Python — either the vendor-local one set up by install.sh,
# or the user's existing wechat-mcp install as fallback.

def _wechat_python():
    """Find a wechat-mcp venv whose Python can actually `import wechat_mcp`.

    Skipping the import check leaks a footgun: a venv whose `pip install -e .`
    silently failed (leaving only setuptools/pip) still has `bin/python`
    present, so a binary-only check picks it and every wx command blows up
    with ModuleNotFoundError. Validate the module is importable too.
    """
    candidates = [
        VENDOR / "wechat-mcp" / ".venv" / "bin" / "python",
        Path.home() / ".local/share/mcp-servers/wechat-mcp/.venv/bin/python",
    ]
    broken = []
    for p in candidates:
        if not (p.is_file() and os.access(p, os.X_OK)):
            continue
        try:
            r = subprocess.run([str(p), "-c", "import wechat_mcp"],
                               capture_output=True, text=True, timeout=10)
            if r.returncode == 0:
                return p
            broken.append((p, (r.stderr or "import failed").strip().splitlines()[-1][:120]))
        except (subprocess.TimeoutExpired, OSError) as e:
            broken.append((p, str(e)[:120]))
    msg = ["macli wx: no working wechat-mcp venv found. run ./install.sh or macli doctor --fix."]
    if broken:
        msg.append("  detected broken venvs (python present but wechat_mcp not importable):")
        for p, why in broken:
            msg.append(f"    {p}  →  {why}")
    msg.append(f"  candidates checked: {' , '.join(str(c) for c in candidates)}")
    print("\n".join(msg), file=sys.stderr)
    sys.exit(1)


def _run_wechat_helper(script):
    py = _wechat_python()
    res = subprocess.run([str(py), "-c", script], capture_output=True, text=True, timeout=60)
    if res.stderr:
        sys.stderr.write(res.stderr)
    return res


def _wx_stage_and_send(contact, payload, is_file, payload_path):
    """Steps: stage clipboard → navigate to contact → cmd+V + Return.

    Returns (ok, error_code, error_message). On ok=True caller still needs to
    verify the send via AX poll if verification is desired.
    """
    if is_file:
        stage = f"""
import sys
from AppKit import NSPasteboard, NSURL
pb = NSPasteboard.generalPasteboard()
pb.clearContents()
pb.writeObjects_([NSURL.fileURLWithPath_({repr(str(payload_path.resolve()))})])
print("clip_ok")
"""
    else:
        stage = f"""
import subprocess
subprocess.run(['pbcopy'], input={repr(payload.encode('utf-8'))}, check=True)
print("clip_ok")
"""
    r = _run_wechat_helper(stage)
    if "clip_ok" not in r.stdout:
        return False, "internal_error", "failed to stage clipboard"

    nav = f"""
import sys, json
from wechat_mcp.wechat_accessibility import open_chat_for_contact
res = open_chat_for_contact({repr(contact)})
print("nav_done")
print(json.dumps(res, default=str))
"""
    r = _run_wechat_helper(nav)
    if "nav_done" not in r.stdout:
        return False, "not_found", f"could not navigate to '{contact}'"
    time.sleep(0.4)

    osascript('''
    tell application "WeChat" to activate
    tell application "System Events" to tell process "WeChat"
        keystroke "v" using command down
        delay 0.9
        key code 36
    end tell
    ''')
    return True, None, None


def _wx_verify_last_message(timeout):
    """Best-effort L2 verification: poll WeChat's message-list AX tree to confirm
    the most recent message has no failure indicator (red exclamation / retry button).

    Returns: dict with keys
      verified (bool)         — True if last message has no error icon within timeout
      has_error_icon (bool)   — True if a retry/failed indicator was detected
      detected (str|None)     — which keyword triggered the error detection
      error (str|None)        — internal error if AX traversal threw

    Caveat: detection is heuristic; we look for AX descendants whose
    role/identifier/title/description carry common failure markers. False negatives
    are possible if WeChat's AX surface changes — in that case verified=True is
    returned (no marker found within timeout). For files, callers should give
    longer timeout to absorb upload time.
    """
    script = f'''
import time, json
out = {{"verified": False, "has_error_icon": False, "detected": None, "error": None}}
try:
    from ApplicationServices import (
        kAXChildrenAttribute, kAXRoleAttribute, kAXIdentifierAttribute,
        kAXTitleAttribute, kAXDescriptionAttribute, kAXValueAttribute,
    )
    from wechat_mcp.wechat_accessibility import get_wechat_ax_app, ax_get
    from wechat_mcp.fetch_messages_by_chat_utils import get_messages_list
except Exception as e:
    out["error"] = "import_failed: " + str(e)
    print(json.dumps(out)); raise SystemExit(0)

# WeChat 4.x failure signals are diverse:
#   - "重发" / "resend" — retry button on a failed bubble (network drop, etc.)
#   - "发送失败" / "send failed" — inline error text
#   - "消息已发出，但被对方拒收了。" — system-message row inserted after
#     the user bubble when the recipient has deleted/blocked the sender
#   - "已被对方拉黑" — blocking notice (rare)
#   - "rejected" — English UI variant
FAIL_KEYWORDS = (
    "retry", "resend", "重发", "重新发送",
    "发送失败", "send failed", "failed to send",
    "被对方拒收", "已被对方拒收", "rejected by",
    "已被对方拉黑", "拉黑",
)

def find_failure(el, depth=0):
    if depth > 6:
        return None
    try:
        role = ax_get(el, kAXRoleAttribute) or ""
        ident = ax_get(el, kAXIdentifierAttribute) or ""
        title = ax_get(el, kAXTitleAttribute) or ""
        desc = ax_get(el, kAXDescriptionAttribute) or ""
        val = ax_get(el, kAXValueAttribute) or ""
        blob = (str(ident) + " " + str(title) + " " + str(desc) + " " + str(val)).lower()
        for kw in FAIL_KEYWORDS:
            if kw.lower() in blob:
                return kw
        for child in ax_get(el, kAXChildrenAttribute) or []:
            r = find_failure(child, depth + 1)
            if r: return r
    except Exception:
        pass
    return None

deadline = time.time() + {timeout}
last_error = None
polls = 0
empty_polls = 0
max_rows_seen = 0
saw_rows = False

# Failure signals can land as a separate system-message row inserted AFTER
# the user's bubble; scan the most recent few rows, not just rows[-1].
# Strategy: poll until we either spot a failure mark or run out of time.
# Each AX traversal is ~3-5s on a busy chat, so we lean on the full timeout
# as the observation window itself — no second-derivative "clean counter".
SCAN_RECENT = 3

while time.time() < deadline:
    polls += 1
    try:
        app = get_wechat_ax_app()
        msg_list = get_messages_list(app)
        rows = ax_get(msg_list, "AXRows") or ax_get(msg_list, kAXChildrenAttribute) or []
        if len(rows) > max_rows_seen:
            max_rows_seen = len(rows)
        if rows:
            saw_rows = True
            mark = None
            for r in rows[-SCAN_RECENT:]:
                m = find_failure(r)
                if m:
                    mark = m
                    break
            if mark:
                out["has_error_icon"] = True
                out["detected"] = mark
                out["verified"] = False
                break
        else:
            empty_polls += 1
    except Exception as e:
        last_error = str(e)
    time.sleep(0.35)

# Final decision:
#   - mark found → has_error_icon already set, verified=False
#   - rows visible at least once during the full timeout window, never any mark
#     → confident no failure, verified=True
#   - never saw rows → AX dead/permission/chat empty → can't verify
if not out["has_error_icon"]:
    if saw_rows:
        out["verified"] = True
    elif last_error:
        out["error"] = last_error
    else:
        out["error"] = "no message rows visible during verify window"

out["_debug"] = {{"polls": polls, "empty_polls": empty_polls,
                  "max_rows_seen": max_rows_seen}}

print(json.dumps(out, ensure_ascii=False, default=str))
'''
    r = _run_wechat_helper(script)
    raw = (r.stdout or "").strip().splitlines()
    if not raw:
        return {"verified": False, "has_error_icon": False, "error": "no helper output"}
    try:
        return json.loads(raw[-1])
    except json.JSONDecodeError:
        return {"verified": False, "has_error_icon": False, "error": f"non-JSON: {raw[-1][:120]}"}


def _parse_int_flag(args, flag, default):
    if flag not in args:
        return default, args
    i = args.index(flag)
    if i + 1 >= len(args):
        return default, args
    try:
        val = int(args[i + 1])
    except ValueError:
        return default, args
    return val, args[:i] + args[i + 2:]


# Failure-code → notification title. Distinct titles let users triage at a
# glance: "拒收" (永久 — 拉黑/拒收) vs "状态不明" (verify 超时) vs general "失败".
_WX_FAIL_TITLES = {
    "send_failed_at_recipient": "macli wx: 已被拒收",
    "verify_timeout":           "macli wx: 状态不明",
    "send_failed":              "macli wx: 发送失败",
    "not_found":                "macli wx: 联系人未找到",
    "verify_error":             "macli wx: 校验异常",
    "internal_error":           "macli wx: 内部错误",
}


def _wx_send_record(contact, kind, ok, attempts, code=None,
                    detected=None, msg=None):
    """Append one NDJSON line to ~/.tx/wx_send.log, and on failure ALSO fire a
    desktop notification when stdout is not a TTY (cron/launchd/agent).

    Rationale: an interactive terminal already shows stderr + the failed
    bubble in WeChat, so a banner is just noise. Non-interactive callers
    (cron, agent subprocess, redirected stdout) need the active signal —
    otherwise failures live and die in a log no human reads.
    """
    # 1. Structured append-only log (success + failure)
    try:
        CACHE_DIR.mkdir(parents=True, exist_ok=True)
        log_path = CACHE_DIR / "wx_send.log"
        entry = {
            "ts": time.strftime("%Y-%m-%dT%H:%M:%S"),
            "contact": contact,
            "kind": kind,
            "ok": bool(ok),
            "attempts": attempts,
            "error_code": code,
            "detected": detected,
        }
        with log_path.open("a", encoding="utf-8") as f:
            f.write(json.dumps(entry, ensure_ascii=False) + "\n")
    except OSError:
        pass

    # 2. Conditional notification — only on failure, only when non-interactive
    if ok:
        return
    try:
        is_tty = sys.stdout.isatty()
    except (ValueError, AttributeError):
        is_tty = False
    if is_tty:
        return
    title = _WX_FAIL_TITLES.get(code, "macli wx: 失败")
    detail = detected or (msg or "")
    body = f"→ {contact}  ({detail[:60]})" if detail else f"→ {contact}"
    _notify_user(title, body)


def cmd_wx_send(args):
    as_json, args = _pop_flag(list(args), "--json")
    no_verify, args = _pop_flag(args, "--no-verify")

    # Parse --retry N (default 1; only attempts a single retry after a failure)
    retry_n, args = _parse_int_flag(args, "--retry", 1)
    retry_n = max(0, retry_n)

    # Optional override of verify timeout
    verify_timeout, args = _parse_int_flag(args, "--verify-timeout", -1)

    if len(args) < 2:
        msg = "usage: macli wx send <contact> <text-or-file-path> [--retry N] [--no-verify]"
        if as_json:
            _emit_err("invalid_args", msg)
        else:
            print(msg, file=sys.stderr)
        return 2

    contact, payload = args[0], args[1]
    payload_path = Path(payload)
    is_file = payload_path.is_file()
    kind = "file" if is_file else "text"
    preview = str(payload_path.resolve()) if is_file else payload[:200]

    if verify_timeout <= 0:
        # Text: server round-trip + recipient-side check (e.g. block / 拒收
        # system message) can take 3-5s before WeChat inserts the failure row.
        # File: upload time dominates; 30s is a reasonable cap, override with
        # --verify-timeout for larger files.
        verify_timeout = 30 if is_file else 6

    # Recipient-side rejection (block / 拒收 / account deleted) is permanent
    # for this run — retrying just spams the chat and risks AX flakiness.
    NON_RETRIABLE = ("被对方拒收", "已被对方拒收", "已被对方拉黑", "拉黑", "rejected by")

    def _confirmed_recipient_rejection(v):
        if not v or not v.get("has_error_icon"):
            return False
        d = (v.get("detected") or "").lower()
        return any(kw.lower() in d for kw in NON_RETRIABLE)

    last_verify = None
    last_perform_err = None
    attempts = 0
    while attempts <= retry_n:
        attempts += 1
        ok, err_code, err_msg = _wx_stage_and_send(contact, payload, is_file, payload_path)
        if not ok:
            last_perform_err = (err_code, err_msg)
            if attempts > retry_n:
                break
            time.sleep(0.8)
            continue

        if no_verify:
            data = {"contact": contact, "kind": kind, "payload_preview": preview,
                    "sent_at": time.strftime("%Y-%m-%dT%H:%M:%S"),
                    "verified": False, "verify_skipped": True, "attempts": attempts}
            if as_json:
                _emit_ok(data)
            else:
                print(f"✓ sent {kind} → {contact}  (unverified)")
            _wx_send_record(contact, kind, True, attempts)
            return 0

        v = _wx_verify_last_message(verify_timeout)
        last_verify = v
        if v.get("verified"):
            data = {"contact": contact, "kind": kind, "payload_preview": preview,
                    "sent_at": time.strftime("%Y-%m-%dT%H:%M:%S"),
                    "verified": True, "attempts": attempts}
            if as_json:
                _emit_ok(data)
            else:
                print(f"✓ sent {kind} → {contact}  (verified)")
            _wx_send_record(contact, kind, True, attempts)
            return 0

        # If verify positively confirmed a permanent failure, stop retrying.
        if _confirmed_recipient_rejection(v):
            break
        if attempts > retry_n:
            break
        time.sleep(0.8)

    # All attempts exhausted. Pick the most informative error:
    # 1. A verified-failure signal (red icon / system rejection) beats
    #    a transient perform error from a later retry.
    # 2. Otherwise fall back to the perform error (e.g. navigation failed).
    # 3. Otherwise pure verify timeout.
    if last_verify and last_verify.get("has_error_icon"):
        code = ("send_failed_at_recipient"
                if _confirmed_recipient_rejection(last_verify)
                else "send_failed")
        msg = f"WeChat surfaced a failure indicator (matched: {last_verify.get('detected')!r})"
    elif last_perform_err:
        code, msg = last_perform_err
    elif last_verify and last_verify.get("error"):
        code = "verify_error"
        msg = f"verification could not run: {last_verify.get('error')}"
    else:
        code = "verify_timeout"
        msg = f"verification timed out after {verify_timeout}s × {attempts} attempt(s)"

    if as_json:
        _emit_err(code, msg, data={"contact": contact, "kind": kind,
                                    "attempts": attempts, "last_verify": last_verify})
    else:
        print(f"macli wx: send failed after {attempts} attempt(s): {msg}", file=sys.stderr)
    _wx_send_record(contact, kind, False, attempts, code=code,
                    detected=(last_verify or {}).get("detected"), msg=msg)
    return 1


def cmd_wx_read(args):
    as_json, args = _pop_flag(args, "--json")
    if not args:
        msg = "usage: macli wx read <contact> [--limit N]"
        if as_json:
            _emit_err("invalid_args", msg)
        else:
            print(msg, file=sys.stderr)
        return 2
    contact = args[0]; limit = 10
    if "--limit" in args:
        i = args.index("--limit")
        if i + 1 < len(args):
            limit = int(args[i + 1])

    # fetch_recent_messages operates on the currently-open chat, so we have
    # to navigate first. (The patched wechat-mcp source only exports
    # fetch_recent_messages — not fetch_messages_by_chat — so an older copy
    # of this command that imported the latter was always broken.)
    script = f"""
import json
from dataclasses import asdict, is_dataclass
from wechat_mcp.wechat_accessibility import open_chat_for_contact
from wechat_mcp.fetch_messages_by_chat_utils import fetch_recent_messages

nav = open_chat_for_contact({repr(contact)})
if nav and isinstance(nav, dict) and nav.get("error"):
    print(json.dumps({{"_macli_error": "navigation_failed", "detail": nav.get("error")}}, ensure_ascii=False))
    raise SystemExit(0)

msgs = fetch_recent_messages(last_n={limit})

def _norm(m):
    if is_dataclass(m): return asdict(m)
    return m

print(json.dumps([_norm(m) for m in msgs], ensure_ascii=False, default=str))
"""
    r = _run_wechat_helper(script)
    raw = r.stdout.strip()
    if r.returncode != 0 or not raw:
        msg = (r.stderr or f"exit {r.returncode}").strip()[:200]
        if as_json:
            _emit_err("subprocess_failed", msg)
        else:
            sys.stdout.write(r.stdout)
        return r.returncode or 1
    try:
        msgs = json.loads(raw)
    except json.JSONDecodeError:
        if as_json:
            _emit_err("internal_error", f"helper returned non-JSON: {raw[:200]}")
        else:
            sys.stdout.write(r.stdout)
        return 1
    if as_json:
        _emit_ok({
            "contact": contact,
            "count": len(msgs) if isinstance(msgs, list) else (
                len(msgs.get("result", [])) if isinstance(msgs, dict) else 0
            ),
            "messages": msgs,
        })
    else:
        print(json.dumps(msgs, indent=2, ensure_ascii=False, default=str))
    return r.returncode


def cmd_wx_contacts(args):
    """List WeChat contacts (chat sessions) currently exposed in the sidebar.

    Uses wechat-mcp's collect_chat_elements(). Returns the set of chat names
    the AX tree can reach without scrolling/search. On WeChat 4.x this is
    typically the user's full session history.
    """
    as_json, args = _pop_flag(args, "--json")
    filt = args[0] if args else None

    script = '''
import json
try:
    from wechat_mcp.wechat_accessibility import get_wechat_ax_app, collect_chat_elements
    app = get_wechat_ax_app()
    chats = collect_chat_elements(app)
    print(json.dumps(sorted(chats.keys()), ensure_ascii=False))
except Exception as e:
    print(json.dumps({"error": str(e)}, ensure_ascii=False))
'''
    r = _run_wechat_helper(script)
    raw = (r.stdout or "").strip().splitlines()
    if not raw:
        msg = "no helper output (is WeChat running and Accessibility granted?)"
        if as_json:
            _emit_err("subprocess_failed", msg)
        else:
            print(f"macli wx: {msg}", file=sys.stderr)
        return 1
    try:
        parsed = json.loads(raw[-1])
    except json.JSONDecodeError:
        msg = f"helper returned non-JSON: {raw[-1][:120]}"
        if as_json:
            _emit_err("internal_error", msg)
        else:
            print(f"macli wx: {msg}", file=sys.stderr)
        return 1

    if isinstance(parsed, dict) and "error" in parsed:
        if as_json:
            _emit_err("subprocess_failed", parsed["error"])
        else:
            print(f"macli wx contacts: {parsed['error']}", file=sys.stderr)
        return 1

    names = parsed if isinstance(parsed, list) else []
    if filt:
        f = filt.lower()
        names = [n for n in names if f in n.lower()]

    if as_json:
        _emit_ok({"count": len(names), "contacts": names})
    else:
        for n in names:
            print(n)
        print(f"\n({len(names)} contacts)")
    return 0


def route_wechat(args):
    # Tier 1: standalone `macli wx [--json]` lists subcommands
    if not args or args == ["--json"]:
        return _emit_namespace_listing("wx", WX_SUBCOMMANDS, args)
    sub, rest = args[0], args[1:]
    # Tier 3: --help intercept BEFORE dispatching to cmd_wx_*
    if _has_help_flag(rest) or sub in ("--help", "-h", "help"):
        target = sub if sub not in ("--help", "-h", "help") else (rest[0] if rest else None)
        if target is None or target not in WX_SUBCOMMANDS:
            return _emit_subcommand_help("wx send", rest)  # default to send help
        return _emit_subcommand_help(f"wx {target}", rest)
    if sub == "send":     return cmd_wx_send(rest)
    if sub == "read":     return cmd_wx_read(rest)
    if sub == "contacts": return cmd_wx_contacts(rest)
    print(f"macli wx: unknown subcommand '{sub}'", file=sys.stderr); return 2


# =============================================================================
# macOS subsystem (osascript + vendor/macos-automator-mcp KB)
# =============================================================================

_KB_CACHE = None


def _kb_index():
    global _KB_CACHE
    if _KB_CACHE is not None: return _KB_CACHE
    if not MACOS_AUTOMATOR_KB.is_dir():
        _KB_CACHE = {}; return _KB_CACHE
    idx = {}
    for md in MACOS_AUTOMATOR_KB.rglob("*.md"):
        try: content = md.read_text(encoding="utf-8")
        except OSError: continue
        m = re.search(r"^id:\s*([\w-]+)\s*$", content, re.MULTILINE)
        if m: idx[m.group(1)] = md
    _KB_CACHE = idx
    return idx


def _kb_extract_script(md_path):
    text = md_path.read_text(encoding="utf-8")
    blocks = re.findall(r"```(?:applescript|javascript)?\s*\n(.*?)\n```", text, re.DOTALL)
    if not blocks: return None, None
    fm = re.search(r"^language:\s*(\w+)\s*$", text, re.MULTILINE)
    return blocks[0], (fm.group(1) if fm else "applescript")


def cmd_mac_kb(args):
    as_json, args = _pop_flag(args, "--json")
    if not args:
        if as_json:
            _emit_err("invalid_args", "usage: macli mac kb <script-id> [arg1 ...]")
        else:
            print("usage: macli mac kb <script-id> [arg1 ...]", file=sys.stderr)
        return 2
    script_id, script_args = args[0], args[1:]
    idx = _kb_index()
    if script_id not in idx:
        if as_json:
            _emit_err("not_found", f"kb id '{script_id}' not found")
        else:
            print(f"macli mac kb: id '{script_id}' not found", file=sys.stderr)
        return 1
    script, lang = _kb_extract_script(idx[script_id])
    if script is None:
        if as_json:
            _emit_err("internal_error", f"no code block in {idx[script_id]}")
        else:
            print(f"macli mac kb: no code block in {idx[script_id]}", file=sys.stderr)
        return 1
    for i, val in enumerate(script_args, 1):
        script = script.replace(f"--MCP_ARG_{i}", val)
    cmd = ["osascript"] + (["-l", "JavaScript"] if lang.lower() in ("javascript", "jxa") else []) + ["-e", script]
    r = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
    if as_json:
        data = {
            "script_id": script_id, "args": script_args,
            "exit_code": r.returncode, "stdout": r.stdout, "stderr": r.stderr,
        }
        if r.returncode == 0:
            _emit_ok(data)
        else:
            _emit_err("subprocess_failed",
                      r.stderr.strip() or f"exit {r.returncode}", data=data)
        return r.returncode
    sys.stdout.write(r.stdout); sys.stderr.write(r.stderr)
    return r.returncode


def cmd_mac_kb_list(args):
    as_json, _ = _pop_flag(args, "--json")
    idx = _kb_index()
    scripts = [
        {"id": kb_id, "path": str(idx[kb_id].relative_to(MACOS_AUTOMATOR_KB))}
        for kb_id in sorted(idx)
    ]
    if as_json:
        _emit_ok({"count": len(scripts), "scripts": scripts})
        return 0
    for s in scripts:
        print(f"  {s['id']:48s}  {s['path']}")
    print(f"\n({len(scripts)} scripts)")
    return 0


KB_SEARCH_INDEX = CACHE_DIR / "kb-search-index.json"


def _kb_parse_frontmatter(text):
    """Parse a KB md's YAML frontmatter. Stdlib-only; only handles the shapes
    actually used by macos-automator-mcp's KB (scalars + folded `>-` + simple
    bullet lists). Returns dict with id/title/description/keywords/category."""
    m = re.match(r"^---\n(.*?)\n---", text, re.DOTALL)
    if not m:
        return None
    fm = m.group(1)
    out = {"id": "", "title": "", "description": "", "keywords": [], "category": ""}
    for key in ("id", "title", "category", "language"):
        m2 = re.search(rf'^{key}:\s*"?([^"\n]*?)"?\s*$', fm, re.MULTILINE)
        if m2:
            out[key if key != "language" else "category"] = (
                out.get(key if key != "language" else "category") or m2.group(1).strip()
            )
    # Folded description (>-) or single-line
    m3 = re.search(r"^description:\s*>-?\s*\n((?:  .*\n?)+)", fm, re.MULTILINE)
    if m3:
        out["description"] = " ".join(l.strip() for l in m3.group(1).splitlines() if l.strip())
    else:
        m3 = re.search(r'^description:\s*"?([^"\n]*?)"?\s*$', fm, re.MULTILINE)
        if m3:
            out["description"] = m3.group(1).strip()
    # Keywords as YAML list
    m4 = re.search(r"^keywords:\s*\n((?:  - .*\n?)+)", fm, re.MULTILINE)
    if m4:
        out["keywords"] = [
            re.sub(r'^  - ', "", l).strip().strip('"')
            for l in m4.group(1).splitlines()
            if l.strip()
        ]
    return out


def _kb_newest_mtime(kb_dir):
    newest = 0.0
    for p in kb_dir.rglob("*.md"):
        try:
            m = p.stat().st_mtime
            if m > newest:
                newest = m
        except OSError:
            pass
    return newest


def _kb_build_search_index(kb_dir, idx_path):
    entries = []
    for md in kb_dir.rglob("*.md"):
        try:
            text = md.read_text(encoding="utf-8")
        except OSError:
            continue
        fm = _kb_parse_frontmatter(text)
        if not fm or not fm.get("id"):
            continue
        entries.append({
            "id": fm["id"],
            "title": fm["title"],
            "description": fm["description"],
            "keywords": fm["keywords"],
            "category": fm["category"],
            "path": str(md.relative_to(kb_dir)),
        })
    idx_path.parent.mkdir(parents=True, exist_ok=True)
    idx_path.write_text(
        json.dumps({"kb_mtime": _kb_newest_mtime(kb_dir), "entries": entries},
                   ensure_ascii=False),
        encoding="utf-8",
    )
    return entries


def _kb_load_search_index():
    if not MACOS_AUTOMATOR_KB.is_dir():
        return []
    if not KB_SEARCH_INDEX.exists():
        return _kb_build_search_index(MACOS_AUTOMATOR_KB, KB_SEARCH_INDEX)
    try:
        cached = json.loads(KB_SEARCH_INDEX.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return _kb_build_search_index(MACOS_AUTOMATOR_KB, KB_SEARCH_INDEX)
    cached_mtime = float(cached.get("kb_mtime", 0))
    if _kb_newest_mtime(MACOS_AUTOMATOR_KB) > cached_mtime + 1:
        return _kb_build_search_index(MACOS_AUTOMATOR_KB, KB_SEARCH_INDEX)
    return cached.get("entries", [])


def _kb_tokenize(s):
    return [t for t in re.split(r"[^\w]+", (s or "").lower()) if len(t) >= 2]


def _kb_score(entry, query_tokens):
    """Weighted token-overlap score. Title > keywords > id > description > category."""
    title_t = set(_kb_tokenize(entry.get("title", "")))
    desc_t = set(_kb_tokenize(entry.get("description", "")))
    kw_t = set()
    for k in entry.get("keywords", []) or []:
        kw_t.update(_kb_tokenize(k))
    id_t = set(_kb_tokenize(entry.get("id", "")))
    cat_t = set(_kb_tokenize(entry.get("category", "")))
    score = 0.0
    for q in query_tokens:
        if q in title_t: score += 3.0
        if q in kw_t:    score += 2.5
        if q in id_t:    score += 1.5
        if q in desc_t: score += 1.0
        if q in cat_t:   score += 0.5
    return score


def cmd_mac_kb_search(args):
    as_json, args = _pop_flag(args, "--json")
    max_n, args = _parse_int_flag(args, "--max", 10)
    max_n = max(1, max_n)

    if not args:
        msg = "usage: macli mac kb-search <query> [--max N]"
        if as_json:
            _emit_err("invalid_args", msg)
        else:
            print(msg, file=sys.stderr)
        return 2

    query = " ".join(args)
    tokens = _kb_tokenize(query)
    entries = _kb_load_search_index()
    if not tokens:
        if as_json:
            _emit_ok({"query": query, "count": 0,
                      "indexed": len(entries), "results": []})
        else:
            print("(no searchable tokens in query)")
        return 0

    scored = []
    for e in entries:
        s = _kb_score(e, tokens)
        if s > 0:
            scored.append((s, e))
    scored.sort(key=lambda x: x[0], reverse=True)
    top = scored[:max_n]

    if as_json:
        _emit_ok({
            "query": query,
            "indexed": len(entries),
            "count": len(top),
            "results": [{
                "id": e["id"],
                "title": e["title"],
                "path": e["path"],
                "score": round(s, 2),
                "description": (e.get("description") or "")[:200],
                "keywords": e.get("keywords") or [],
            } for s, e in top],
        })
        return 0
    if not top:
        print(f"(no matches in {len(entries)} indexed scripts)")
        return 0
    for s, e in top:
        print(f"  {e['id']:42s}  score={s:.1f}  {e.get('title','')}")
    print(f"\n({len(top)} results / {len(entries)} indexed)")
    return 0


def cmd_mac_script(args):
    as_json, args = _pop_flag(args, "--json")
    if not args:
        if as_json:
            _emit_err("invalid_args", "usage: macli mac script '<applescript code>'")
        else:
            print("usage: macli mac script '<applescript code>'", file=sys.stderr)
        return 2
    r = osascript(args[0], timeout=60)
    if as_json:
        data = {"exit_code": r.returncode, "stdout": r.stdout, "stderr": r.stderr}
        if r.returncode == 0:
            _emit_ok(data)
        else:
            _emit_err("subprocess_failed",
                      r.stderr.strip() or f"exit {r.returncode}", data=data)
        return r.returncode
    sys.stdout.write(r.stdout); sys.stderr.write(r.stderr)
    return r.returncode


