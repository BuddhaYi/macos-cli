def _has_help_flag(args):
    """True if the args carry a --help / -h that should trigger per-cmd help."""
    return "--help" in args or "-h" in args


def _emit_subcommand_help(cmd_path, args):
    """Resolve `macli <cmd-path> --help [--json]` to the registered CMD_INFO entry.

    Returns the exit code (always 0 if found; 1 if not in registry).
    """
    as_json, _ = _pop_flag([a for a in args if a not in ("--help", "-h")], "--json")
    info = CMD_INFO.get(cmd_path)
    if not info:
        msg = f"no registered help for: {cmd_path}  (try: macli help --json | jq .data.commands)"
        if as_json:
            _emit_err("not_found", msg, data={"available": sorted(CMD_INFO.keys())})
        else:
            print(msg, file=sys.stderr)
        return 1
    if as_json:
        _emit_ok({"command": cmd_path, **info})
        return 0
    # Human format
    print(f"# {cmd_path}")
    print(f"  {info['synopsis']}\n")
    print(f"  {info.get('summary','')}\n")
    if info.get("behavior"):
        print("  Behavior:")
        for line in info["behavior"]:
            print(f"    - {line}")
        print()
    if info.get("see_also"):
        print(f"  See also: {', '.join(info['see_also'])}")
    return 0


def _emit_namespace_listing(ns, subcommands, args):
    """Handle `macli <ns> [--json]` standalone (no subcommand)."""
    as_json, _ = _pop_flag(args, "--json")
    if as_json:
        _emit_ok({
            "namespace": ns,
            "subcommands": subcommands,
            "discover_per_command": f"macli help {ns} <subcommand> --json",
        })
        return 0
    print(f"usage: macli {ns} <{'|'.join(subcommands)}> [args...]", file=sys.stderr)
    return 2


def suggest_similar(cmd, candidates):
    matches = difflib.get_close_matches(cmd, candidates, n=3, cutoff=0.6)
    if matches:
        print(f"  did you mean: {', '.join(matches)}?", file=sys.stderr)


def _notify_user(title, message, sound="Submarine"):
    """Fire a macOS desktop notification. Best-effort; ignores any failure."""
    try:
        safe_title = (title or "").replace('"', "'")
        safe_msg = (message or "").replace('"', "'")
        subprocess.run(
            ["osascript", "-e",
             f'display notification "{safe_msg}" with title "{safe_title}" sound name "{sound}"'],
            capture_output=True, timeout=5,
        )
    except Exception:
        pass


