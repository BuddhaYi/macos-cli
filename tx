  tx <legacy-magpie-cmd> [args...]            # backward compat

NAMESPACES
  tx x <args>          → vendor/magpie/tx (X/Twitter + 132 sites)
  tx wx send <contact> <text|file-path>
  tx wx read <contact> [--limit N]
  tx mac script '<applescript>'
  tx mac kb <script-id> [args...]
