def cmd_help(args):
    print(f"""tx {VERSION}  —  macos-cli unified router

USAGE
  tx <namespace> <action> [args...]
  tx <legacy-x-cmd> [args...]                  # auto-routed to x subsystem

NAMESPACES
  tx x  <args>          X/Twitter (twitter-cli + bird + opencli)
                        e.g. tx x search "Claude Code"
                             tx x archive
                             tx x download --tweet-url <url>
                             tx x post "hello"
  tx wx send <contact> <text|file>
  tx wx read <contact> [--limit N]
