def _run(args):
    try:
        return subprocess.run(args, capture_output=True, text=True, timeout=15)
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return None


def osascript(script, timeout=30):
    return subprocess.run(
        ["osascript", "-e", script],
        capture_output=True, text=True, timeout=timeout,
    )


def exec_or_fail(prog, args):
    if not shutil.which(prog):
        hint = {
            "bird":    "npm i -g @steipete/bird",
            "twitter": "uv tool install twitter-cli",
            "opencli": "npm i -g @jackwener/opencli",
        }.get(prog, "")
        print(f"macli: {prog} not installed{'   →   ' + hint if hint else ''}",
              file=sys.stderr)
        sys.exit(127)
    os.execvp(prog, [prog] + args)


SCHEMA_VERSION = "1"


def _envelope(ok, data=None, error_code=None, error_message=None):
    """Build the standard agent-friendly output envelope (see SCHEMA.md)."""
    out = {"ok": bool(ok), "schema_version": SCHEMA_VERSION}
    if data is not None:
        out["data"] = data
    if not ok:
        out["error"] = {
            "code": error_code or "internal_error",
            "message": error_message or "",
        }
    return out


def _print_json(payload):
    """Dump JSON envelope to stdout with consistent formatting."""
    print(json.dumps(payload, indent=2, ensure_ascii=False, default=str))


def _has_flag(args, *flags):
    """Return True if any of the given flag strings are in args."""
    return any(f in args for f in flags)


def _pop_flag(args, flag):
    """Pop a boolean flag from args. Returns (present, filtered_args).

    Centralizes the `as_json = _has_flag(args, "--json"); args = [...]`
    boilerplate that appears in every command. Caller writes:
        as_json, args = _pop_flag(args, "--json")
    """
    if flag not in args:
        return False, args
    return True, [a for a in args if a != flag]


def _emit_ok(data=None):
    """Print a success envelope to stdout (machine output)."""
    _print_json(_envelope(True, data=data))


def _emit_err(code, message, data=None):
    """Print a failure envelope to stdout. Caller still picks exit code."""
    _print_json(_envelope(False, data=data, error_code=code, error_message=message))


