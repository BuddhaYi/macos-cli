def _load_cookies_env():
    """Read cookies from ~/.tx/cookies.env into env. Exports both bird-style
    (AUTH_TOKEN/CT0) and twitter-cli-style (TWITTER_AUTH_TOKEN/TWITTER_CT0)
    aliases so all 3 backends find the cookies."""
    if not COOKIES_FILE.exists():
        return
    try:
        for line in COOKIES_FILE.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, _, v = line.partition("=")
            k, v = k.strip(), v.strip()
            os.environ.setdefault(k, v)
            # mirror to twitter-cli's expected env var names
            if k == "AUTH_TOKEN":
                os.environ.setdefault("TWITTER_AUTH_TOKEN", v)
            elif k == "CT0":
                os.environ.setdefault("TWITTER_CT0", v)
    except OSError:
        pass


def _cookies_status():
    """Return (age_seconds, source, status_label) for ~/.tx/cookies.env, or (None,)*3."""
    if not COOKIES_FILE.exists():
        return None, None, "missing"
    try:
        age = time.time() - COOKIES_FILE.stat().st_mtime
        first_line = COOKIES_FILE.read_text().splitlines()[0]
        # parse "# tx cookies — extracted from <SOURCE> at ..."
        m = re.search(r"extracted from (\S+(?:\s+\S+)?)\s+at", first_line)
        source = m.group(1) if m else "unknown"
    except (OSError, IndexError):
        return None, None, "unreadable"
    days = age / 86400
    if days < 30:    label = "fresh"
    elif days < 60:  label = "aging"
    elif days < 90:  label = "stale (renew soon)"
    else:            label = "expired (renew NOW)"
    return age, source, label


def _is_auth_error(stderr_text):
    """Heuristic: bird auth failure → suggests cookies need renewal."""
    if not stderr_text:
        return False
    s = stderr_text.lower()
    return any(k in s for k in (
        "401", "could not authenticate", "missing required credentials",
        "no twitter cookies", "missing auth_token", "missing ct0",
    ))


SWEET_COOKIE_DIR = (
    NPM_GLOBAL_LIB / "@steipete" / "bird" / "node_modules" / "@steipete" / "sweet-cookie"
)
EDGE_PROFILE_DIR = (
    Path.home() / "Library" / "Application Support" / "Microsoft Edge Beta" / "Default"
)
EDGE_STABLE_PROFILE_DIR = (
    Path.home() / "Library" / "Application Support" / "Microsoft Edge" / "Default"
)


def _extract_cookies_via_provider(provider_path, opts_json):
    """Run a sweet-cookie provider (edge / chrome / safari / firefox) directly.

    Returns (auth_token, ct0, source) tuple or raises RuntimeError.
    """
    js = (
        f"const p = require('./dist/providers/{provider_path}');"
        f"const fn = Object.values(p)[0];"  # each provider exports one fn
        f"fn({opts_json}, ['https://x.com','https://twitter.com'], null).then(r => {{"
        "  const cs = r.cookies || [];"
        "  const auth = cs.find(c => c.name === 'auth_token');"
        "  const ct0  = cs.find(c => c.name === 'ct0');"
        "  if (!auth || !ct0) {"
        "    console.error('no auth_token/ct0 — make sure x.com is logged in');"
        "    if (r.warnings && r.warnings.length) console.error(r.warnings.join('\\n'));"
        "    process.exit(1);"
        "  }"
        "  console.log(auth.value);"
        "  console.log(ct0.value);"
        "}).catch(e => { console.error(e.message); process.exit(1); });"
    )
    res = subprocess.run(
        ["node", "-e", js],
        cwd=str(SWEET_COOKIE_DIR),
        capture_output=True, text=True, timeout=45,
    )
    if res.returncode != 0:
        raise RuntimeError(res.stderr.strip() or "extraction failed")
    lines = res.stdout.strip().splitlines()
    if len(lines) < 2:
        raise RuntimeError(f"unexpected output: {res.stdout!r}")
    return lines[0], lines[1]


def cmd_cookies_save(rest, cache):
    """Extract X cookies and persist to ~/.tx/cookies.env (mode 0600).

    Default: Edge Beta (most persistent on macOS — no Safari ITP, no annual rotation).
    Override: tx cookies-save --from <edge|edge-stable|chrome|safari|firefox>
    """
    # --check-age: print status and exit, no extraction
    if "--check-age" in rest:
        age, source, label = _cookies_status()
        if age is None:
            print("no cookies file — run `tx cookies-save` to create one")
            return 1
        days = age / 86400
        print(f"source: {source}")
        print(f"age:    {days:.1f} days")
        print(f"status: {label}")
        return 0 if "stale" not in label and "expired" not in label else 2

    browser = "edge"
    if "--from" in rest:
        i = rest.index("--from")
        if i + 1 >= len(rest):
            print("tx cookies-save: --from requires a value", file=sys.stderr)
            return 2
        browser = rest[i + 1]

    if not SWEET_COOKIE_DIR.exists():
        print(f"sweet-cookie not found at {SWEET_COOKIE_DIR}", file=sys.stderr)
        return 1

    common_opts = {"timeoutMs": 30000}
    if browser == "edge":
        if not EDGE_PROFILE_DIR.exists():
            print(f"Edge Beta profile not found: {EDGE_PROFILE_DIR}", file=sys.stderr)
            return 1
        opts = {**common_opts, "profile": str(EDGE_PROFILE_DIR)}
        provider = "edge.js"
        source = "Edge Beta"
    elif browser == "edge-stable":
        opts = {**common_opts, "profile": str(EDGE_STABLE_PROFILE_DIR)}
        provider = "edge.js"
        source = "Edge"
    elif browser == "chrome":
        opts = common_opts
        provider = "chrome.js"
        source = "Chrome"
    elif browser == "safari":
        opts = common_opts
        provider = "safariBinaryCookies.js"
        source = "Safari"
    elif browser == "firefox":
        opts = common_opts
        provider = "firefoxSqlite.js"
        source = "Firefox"
    else:
        print(f"tx cookies-save: unknown browser '{browser}'. "
              f"options: edge, edge-stable, chrome, safari, firefox", file=sys.stderr)
        return 2

    try:
        auth_token, ct0 = _extract_cookies_via_provider(provider, json.dumps(opts))
    except RuntimeError as e:
        print(f"cookie extraction failed:\n{e}", file=sys.stderr)
        return 1
    except subprocess.TimeoutExpired:
        print(f"cookie extraction timed out after 45s "
              f"(may need Keychain approval on first run — try `security unlock-keychain`)", file=sys.stderr)
        return 1
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(dir=str(CACHE_DIR), prefix=".cookies.", suffix=".env")
    try:
        with os.fdopen(fd, "w") as f:
            f.write(f"# tx cookies — extracted from {source} at {time.strftime('%Y-%m-%d %H:%M:%S')}\n")
            f.write(f"AUTH_TOKEN={auth_token}\n")
            f.write(f"CT0={ct0}\n")
        os.chmod(tmp, 0o600)
        os.replace(tmp, COOKIES_FILE)
    except Exception:
        try: os.unlink(tmp)
        except OSError: pass
        raise
    print(f"saved → {COOKIES_FILE}  (source: {source}, mode 0600)")
    print(f"valid until X session expires — re-run `tx cookies-save` after relogin")
    return 0


def _extract_media_urls(node, tweet_id=None, found=None):
    """Recursively find all media dicts in a twitter-cli JSON response, tagging
    each with the containing tweet's id so we can later fetch variants per tweet.
    """
    if found is None:
        found = []
    if isinstance(node, dict):
        # tweet boundary: object with both `id` (str) and `text` (str) is a tweet
        if isinstance(node.get("id"), str) and isinstance(node.get("text"), str):
            tweet_id = node["id"]
        if (
            node.get("type") in ("video", "photo", "animated_gif")
            and isinstance(node.get("url"), str)
            and node["url"].startswith("http")
        ):
            entry = dict(node)
            entry["_tweet_id"] = tweet_id
            found.append(entry)
        for v in node.values():
            _extract_media_urls(v, tweet_id, found)
    elif isinstance(node, list):
        for x in node:
            _extract_media_urls(x, tweet_id, found)
    return found


def _ext_for(media):
    """Pick file extension by media type, falling back to URL."""
    t = media.get("type")
    if t == "video":
        return ".mp4"
    if t == "animated_gif":
        return ".mp4"  # X serves GIFs as MP4
    if t == "photo":
        url = media.get("url", "")
        for ext in (".jpg", ".jpeg", ".png", ".webp", ".gif"):
            if ext in url.lower():
                return ext
        return ".jpg"
    return ".bin"


def _curl_download(url, dest_path):
    """Download URL to file via curl. Returns True on success."""
    res = subprocess.run(
        ["curl", "-fsSL", "-o", str(dest_path), url],
        capture_output=True, text=True, timeout=300,
    )
    return res.returncode == 0


_IMAGE_QUALITY_MAP = {"orig": "orig", "large": "large", "medium": "medium", "small": "small"}


def _upgrade_image_url(url, image_quality="orig"):
    """Force pbs.twimg.com URL to a specific quality level.

    Quality levels (small → orig): 680px → 1200px → 2048px → original upload.
    """
    if "pbs.twimg.com" not in url:
        return url
    name = _IMAGE_QUALITY_MAP.get(image_quality, "orig")
    from urllib.parse import urlparse, urlunparse, parse_qsl, urlencode
    parsed = urlparse(url)
    query = dict(parse_qsl(parsed.query))
    query["name"] = name
    return urlunparse(parsed._replace(query=urlencode(query)))


def _get_video_variants(tweet_id):
    """Fetch all mp4 video variants for a tweet via bird read --json-full.

    Returns list sorted by bitrate descending. Each item: {url, bitrate, width, height}.
    Empty list if bird unavailable or tweet has no video.
    """
    if not shutil.which("bird"):
        return []
    res = _run(["bird", "read", str(tweet_id), "--json-full"])
    if not res or res.returncode != 0:
        return []
    try:
        data = json.loads(res.stdout)
    except json.JSONDecodeError:
        return []
    found = []
    def walk(node):
        if isinstance(node, dict):
            if (
                node.get("content_type") == "video/mp4"
                and isinstance(node.get("url"), str)
            ):
                m = re.search(r"/(\d+)x(\d+)/", node["url"])
                found.append({
                    "url": node["url"],
                    "bitrate": int(node.get("bitrate") or 0),
                    "width": int(m.group(1)) if m else 0,
                    "height": int(m.group(2)) if m else 0,
                })
            for v in node.values():
                walk(v)
        elif isinstance(node, list):
            for x in node:
                walk(x)
    walk(data)
    # dedupe by URL
    seen = set()
    unique = []
    for v in found:
        if v["url"] not in seen:
            seen.add(v["url"])
            unique.append(v)
    return sorted(unique, key=lambda v: (v["bitrate"], v["width"]), reverse=True)


def _select_variant(variants, preference):
    """Pick a variant per preference. preference: 'max' | 'medium' | 'low' | int (target kbps)."""
    if not variants:
        return None
    if preference == "max":
        return variants[0]
    if preference == "low":
        return variants[-1]
    if preference == "medium":
        return variants[len(variants) // 2]
    if isinstance(preference, int):
        target = preference * 1000
        return min(variants, key=lambda v: abs(v["bitrate"] - target))
    return variants[0]


_TWEET_ID_RE = re.compile(r"/status/(\d+)")


def cmd_download(rest, cache):
    """Download media (videos/images) from tweets via twitter-cli + curl.

    Usage:
      tx download <username>               # download user's recent N tweets' media
      tx download --tweet-url <url>        # download a single tweet's media
      tx download --tweet-id <id>          # same, by id
      [--limit N]                          # default 10 for user mode
      [--output DIR]                       # default ./twitter-downloads
    """
    # Parse args
    tweet_id = None
    username = None
    limit = 10
    output_dir = Path("./twitter-downloads")

    i = 0
    while i < len(rest):
        a = rest[i]
        if a == "--tweet-url" and i + 1 < len(rest):
            m = _TWEET_ID_RE.search(rest[i + 1])
            if not m:
                print(f"tx download: cannot parse tweet ID from URL: {rest[i + 1]}", file=sys.stderr)
                return 2
            tweet_id = m.group(1)
            i += 2
        elif a == "--tweet-id" and i + 1 < len(rest):
            tweet_id = rest[i + 1]
            i += 2
        elif a in ("--limit", "-n") and i + 1 < len(rest):
            limit = int(rest[i + 1])
            i += 2
        elif a in ("--output", "-o") and i + 1 < len(rest):
            output_dir = Path(rest[i + 1]).expanduser()
            i += 2
        elif a.startswith("-"):
            print(f"tx download: unknown flag: {a}", file=sys.stderr)
            return 2
        elif username is None and tweet_id is None:
            username = a.lstrip("@")
            i += 1
        else:
            print(f"tx download: unexpected arg: {a}", file=sys.stderr)
            return 2

    if not tweet_id and not username:
        print(cmd_download.__doc__, file=sys.stderr)
        return 2

    if not shutil.which("twitter"):
        print("tx download: twitter-cli not installed   →   uv tool install twitter-cli", file=sys.stderr)
        return 1
    if not shutil.which("curl"):
        print("tx download: curl not found", file=sys.stderr)
        return 1

    _load_cookies_env()
    output_dir.mkdir(parents=True, exist_ok=True)

    # Fetch metadata via twitter-cli
    if tweet_id:
        cmd = ["twitter", "tweet", tweet_id, "--json"]
        label = f"tweet {tweet_id}"
    else:
        cmd = ["twitter", "user-posts", username, "--max", str(limit), "--json"]
        label = f"@{username} (recent {limit})"

    print(f"fetching media list from {label}...")
    res = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
    if res.returncode != 0:
        print(f"twitter-cli failed: {res.stderr.strip()}", file=sys.stderr)
        return 1
    try:
        data = json.loads(res.stdout)
    except json.JSONDecodeError as e:
        print(f"twitter-cli returned invalid JSON: {e}", file=sys.stderr)
        return 1

    media_list = _extract_media_urls(data)
    # Dedupe by URL (some tweets reference same media in multiple places)
    seen = set()
    unique = []
    for m in media_list:
        if m["url"] not in seen:
            seen.add(m["url"])
            unique.append(m)

    if not unique:
        print(f"no media found in {label}")
        return 1

    # Load quality preferences from config
    cfg = _load_config().get("download", {})
    video_q = cfg.get("video_quality", "max")
    image_q = cfg.get("image_quality", "orig")

    print(f"found {len(unique)} media item(s), downloading to {output_dir}/")
    print(f"  quality: video={video_q}, image={image_q}")
    ok, fail = 0, 0
    # Cache variants by tweet_id to avoid duplicate bird calls within a batch
    variant_cache = {}
    for idx, m in enumerate(unique, 1):
        prefix = tweet_id or username
        ext = _ext_for(m)
        dest = output_dir / f"{prefix}_{idx}{ext}"
        if dest.exists():
            print(f"  [{idx}/{len(unique)}] {dest.name} already exists, skip")
            continue

        # Determine the best download URL based on media type
        download_url = m["url"]
        quality_tag = ""
        m_type = m.get("type")

        if m_type == "photo":
            new_url = _upgrade_image_url(m["url"], image_q)
            if new_url != m["url"]:
                download_url = new_url
                quality_tag = f" ({image_q})"
        elif m_type in ("video", "animated_gif"):
            tid = m.get("_tweet_id")
            if tid:
                if tid not in variant_cache:
                    variant_cache[tid] = _get_video_variants(tid)
                variants = variant_cache[tid]
                chosen = _select_variant(variants, video_q)
                if chosen and chosen["url"] != m["url"]:
                    download_url = chosen["url"]
                    quality_tag = f" → {chosen['width']}x{chosen['height']} @ {chosen['bitrate']//1000}k ({video_q})"
                elif chosen:
                    quality_tag = f" ({video_q}, already best)"

        size_hint = (
            f"{m.get('width','?')}x{m.get('height','?')}"
            if m_type == "video" else m_type or "?"
        )
        print(f"  [{idx}/{len(unique)}] {size_hint}{quality_tag} → {dest.name}")
        if _curl_download(download_url, dest):
            ok += 1
        else:
            print(f"     ⚠️  download failed", file=sys.stderr)
            fail += 1

    print(f"\ndone: {ok} downloaded, {fail} failed")
    return 0 if fail == 0 else 1


def cmd_archive(rest, cache):
    """Port of ve-twini archive: bird bookmarks → SQLite."""
    import sqlite3
    from datetime import datetime
    db_path = Path(os.environ.get("TX_DB", "~/.tx/bookmarks.db")).expanduser()
    db_path.parent.mkdir(parents=True, exist_ok=True)

    # Load saved cookies for non-interactive (e.g. launchd) runs
    _load_cookies_env()

    conn = sqlite3.connect(db_path)
    cur = conn.cursor()
    cur.execute("""CREATE TABLE IF NOT EXISTS bookmarks (
        tweet_id TEXT PRIMARY KEY, text TEXT,
        author_username TEXT, author_name TEXT,
        created_at TEXT, raw_json TEXT,
        synced_at TEXT DEFAULT CURRENT_TIMESTAMP)""")
    conn.commit()

    # Prefer twitter-cli for fetch (TLS impersonation = lower rate-limit risk),
    # fall back to bird if twitter-cli not installed.
    use_twitter_cli = shutil.which("twitter") is not None
    if use_twitter_cli:
        r = _run(["twitter", "bookmarks", "--json"])
        backend_label = "twitter-cli"
    else:
        r = _run(["bird", "bookmarks", "--json"])
        backend_label = "bird"

    if not r or r.returncode != 0:
        err = (r.stderr if r else "no result").strip()
        print(f"{backend_label} bookmarks failed: {err}", file=sys.stderr)
        if r and _is_auth_error(err):
            age, source, _ = _cookies_status()
            if age is None:
                print("\n  → cookies missing. run: tx cookies-save", file=sys.stderr)
            else:
                print(f"\n  → cookies likely expired ({age/86400:.0f}d old, from {source}).", file=sys.stderr)
                print("    1) Open Edge Beta → x.com → make sure logged in", file=sys.stderr)
                print("    2) Run: tx cookies-save", file=sys.stderr)
        return 1
    try:
        parsed = json.loads(r.stdout)
        # twitter-cli wraps payload in {ok, schema_version, data: [...]}
        # bird returns a bare list
        if isinstance(parsed, dict) and "data" in parsed:
            data = parsed["data"]
            tweets = data if isinstance(data, list) else data.get("tweets", [])
        else:
            tweets = parsed
    except json.JSONDecodeError as e:
        print(f"{backend_label} returned invalid JSON: {e}", file=sys.stderr)
        return 1

    cur.execute("SELECT tweet_id FROM bookmarks")
    seen = {row[0] for row in cur.fetchall()}
    new = [t for t in tweets if t.get("id") not in seen]

    for t in new:
        author = t.get("author") or {}
        # bird uses author.username, twitter-cli uses author.screenName
        username = author.get("screenName") or author.get("username")
        cur.execute("""INSERT OR REPLACE INTO bookmarks
            (tweet_id, text, author_username, author_name, created_at, raw_json, synced_at)
            VALUES (?, ?, ?, ?, ?, ?, ?)""",
            (t.get("id"), t.get("text"),
             username, author.get("name"),
             t.get("createdAt"), json.dumps(t),
             datetime.utcnow().isoformat()))
    conn.commit()
    conn.close()
    print(f"archived {len(new)} new bookmarks → {db_path}")
    return 0


# ---------- Routing ----------

def suggest_similar(cmd, candidates):
    matches = difflib.get_close_matches(cmd, candidates, n=3, cutoff=0.6)
    if matches:
        print(f"  did you mean: {', '.join(matches)}?", file=sys.stderr)


def exec_or_fail(prog, args):
    if not shutil.which(prog):
        hint = {"bird": "npm i -g @steipete/bird",
                "opencli": "npm i -g @jackwener/opencli"}.get(prog, "")
        print(f"tx: {prog} not installed{'   →   ' + hint if hint else ''}", file=sys.stderr)
        sys.exit(127)
    os.execvp(prog, [prog] + args)


def route(argv):
    # Peel global flags
    via = None
    refresh = False
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--":
            argv = argv[i + 1:]
            break
        if a in ("--help", "-h"):
            cache = load_cache()
            return cmd_help(argv[i + 1:], cache)
        if a == "--version":
            print(VERSION)
            return 0
        if a == "--refresh":
            refresh = True
            i += 1
            continue
        if a == "--via":
            if i + 1 >= len(argv):
                print("tx: --via requires bird|twitter-cli|opencli", file=sys.stderr)
                return 2
            via = argv[i + 1]
            if via not in ("bird", "twitter-cli", "twitter_cli", "opencli"):
                print(f"tx: --via must be bird or opencli, got: {via}", file=sys.stderr)
                return 2
            i += 2
            continue
        # not a known global flag → assume subcommand starts here
        argv = argv[i:]
        break
    else:
        argv = argv[i:]

    cache = load_cache(force_refresh=refresh)
    if refresh and not argv:
        print(f"cache rebuilt: {len(cache['bird'])} bird cmds, "
              f"{len(cache['opencli_twitter'])} opencli twitter cmds, "
              f"{len(cache['opencli_sites'])} adapters")
        return 0

    if not argv:
        return cmd_help([], cache)

    cmd = argv[0]
    rest = argv[1:]

    # Internal
    if cmd == "help":
        return cmd_help(rest, cache)
    if cmd == "auth":
        return cmd_auth(rest, cache)
    if cmd == "doctor":
        return cmd_doctor(rest, cache)
    if cmd == "archive":
        return cmd_archive(rest, cache)
    if cmd == "cookies-save":
        return cmd_cookies_save(rest, cache)
    if cmd == "download":
        return cmd_download(rest, cache)

    bird_cmds = set(cache["bird"])
    tw_cmds = set(cache.get("twitter_cli", []))
    oc_cmds = set(cache["opencli_twitter"])
    sites = set(cache["opencli_sites"])

    # --via override
    if via == "bird":
        if cmd not in bird_cmds:
            print(f"tx: --via bird but '{cmd}' is not a bird command (continuing anyway)", file=sys.stderr)
        exec_or_fail("bird", [cmd] + rest)
    if via in ("twitter-cli", "twitter_cli"):
        if cmd not in tw_cmds:
            print(f"tx: --via twitter-cli but '{cmd}' is not a twitter-cli command (continuing anyway)", file=sys.stderr)
        _load_cookies_env()
        exec_or_fail("twitter", [cmd] + rest)
    if via == "opencli":
        if cmd not in oc_cmds and cmd not in sites:
            print(f"tx: --via opencli but '{cmd}' is not an opencli twitter command (continuing anyway)", file=sys.stderr)
        if cmd in sites:
            exec_or_fail("opencli", [cmd] + rest)
        exec_or_fail("opencli", ["twitter", cmd] + rest)

    # Explicit escape hatches
    if cmd == "bird":
        exec_or_fail("bird", rest)
    if cmd in ("twitter-cli", "twitter_cli"):
        _load_cookies_env()
        exec_or_fail("twitter", rest)

    # Site / app adapter (incl. "twitter" — opencli's site adapter)
    if cmd in sites:
        exec_or_fail("opencli", [cmd] + rest)

    # No name aliasing in v0.3 — `tweet` collides between backends (bird = post,
    # twitter-cli = view by id), and silent translation is dangerous. Users:
    #   - `tx post "text"`   → create a new tweet (twitter-cli)
    #   - `tx tweet <id>`    → view a tweet by id (twitter-cli)
    #   - `tx read <id>`     → view (bird's name)
    in_t = cmd in tw_cmds
    in_b = cmd in bird_cmds
    in_o = cmd in oc_cmds

    # Auto-route — priority: twitter-cli > bird > opencli twitter
    # Rationale (v0.3, "extreme use" optimized):
    #   - twitter-cli has TLS impersonation (curl_cffi) for reads
    #   - twitter-cli has 1.5-4s jitter for writes (built-in anti-bot)
    #   - bird has plain HTTPS — only used for its unique commands (mentions/news/about)
    #   - opencli is browser — only used for its unique commands (block/notifications/etc)
    if in_t:
        _load_cookies_env()
        exec_or_fail("twitter", [cmd] + rest)
    if in_b:
        exec_or_fail("bird", [cmd] + rest)
    if in_o:
        exec_or_fail("opencli", ["twitter", cmd] + rest)

    # Unknown
    all_cmds = bird_cmds | oc_cmds | sites | INTERNAL_CMDS | {"bird"}
    print(f"tx: unknown command: {cmd}", file=sys.stderr)
    suggest_similar(cmd, all_cmds)
    print("  try: tx help", file=sys.stderr)
    return 2


def main():
    try:
        return route(sys.argv[1:]) or 0
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    sys.exit(main())
